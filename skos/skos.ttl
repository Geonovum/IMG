   dct:created "07-04-2020" ;
   skos:definition '''Geeft aan of GeluidbronIndustrie onderdeel is van een normale puntbron, uitstralende gevel of uitstralend dak.'''@nl ;
   skos:note "Benamingen van data types kunnen verschillen per softwarepakket."@nl ;
   dct:source "IMGeluid" ;
.

