   skos:definition '''Verwijzing naar een melding in geval het geval van een windturbine of geluidcontouren van een schiet- of springterrein.'''@nl ;
.

# Construct: IMGeluid Algemeen::Documenttype.monitoringrapportage (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Documenttype/monitoringrapportage>
   a skos:Concept ;
   skos:prefLabel "monitoringrapportage"@nl ;
   rdfs:label "monitoringrapportage" ;
   skos:notation "monitoringrapportage"^^xsd:string ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Documenttype> ;
   skos:definition '''de monitoringrapportage is het voornaamste instrument van bevoegde gezag om: \\n\n                              te monitoren of de GPPs niet worden overschreden,\n                              te monitoren hoe de geluidemissie zich ten opzichte van het BGE ontwikkeld heeft.\n                              de minister en het publiek te informeren over de wijze waarop het bevoegd gezag zorg draagt voor de naleving van de GPPs, danwel de ontwikkeling van BGE\'s.\n                           '''@nl ;
.

