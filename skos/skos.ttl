# Construct: IMGeluid Algemeen::Geluidproductieplafondobject (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject>
   a skos:Concept ;
   skos:prefLabel "Geluidproductieplafondobject"@nl ;
   rdfs:label "Geluidproductieplafondobject" ;
   dct:created "2019-09-12"^^xsd:date ;
   dct:modified "2023-06-15"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/GemonitordObject> ;
   skosthes:narrowerGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/GeluidproductieplafondobjectIndustrie> ;
   dct:created "07-04-2020" ;
   skos:definition '''Een punt in Nederland waar ter referentie is vastgesteld wat de maximale toegstane geluidbelasting per etmaalperiode mag zijn die geproduceerd wordt door een Rijksweg, een provinciale weg, een industrieterrein, of het hoofdspoor.'''@nl ;
   skos:note "Het geluidproductieplafondobject is een verzamelobject dat de in een besluit vastgestelde  GPP-waarde op een referentiepunt opslaat, samen met informatie over een eventueel van toepassing zijnde ontheffing of een vrijstelling."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Geluidproductieplafondobject.geometrieReferentiepunt (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject/geometrieReferentiepunt>
   a skos:Concept ;
   skos:prefLabel "geometrieReferentiepunt"@nl ;
   rdfs:label "geometrieReferentiepunt" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject> ;
   dct:created "06-05-2020" ;
   skos:definition '''De als een 3D punt gemodelleerde meetkundige representatie van de locatie, van een door het bevoegd gezag vastgesteld geluidproductieplafond, op vaste afstand t.o.v. van een rijksweg, een provinciale weg, een spoorbaan of een industrieterrein.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Geluidproductieplafondobject.hoogteReferentiepunt (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject/hoogteReferentiepunt>
   a skos:Concept ;
   skos:prefLabel "hoogteReferentiepunt"@nl ;
   rdfs:label "hoogteReferentiepunt" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject> ;
   dct:created "06-05-2020" ;
   skos:definition '''Hoogteverschil tussen de z-waarde uit de geometrie van referentiepunt en het plaatselijk maaiveld uitgedruk in meters met 1 cijfer achter de komma.'''@nl ;
   skos:note " Bij het bepalen van de hoogte van referentiepunten kan worden uitgegaan van een gemiddelde maaiveldhoogte rond een referentiepunt. Voor het bepalen van een gemiddelde maaiveldhoogte wordt het maximale gebied bepaald door een cirkel met straal 10 m rond het referentiepunt. Ten opzichte van dat gemiddelde mag de hoogte niet meer dan 10% af te wijken van 4,0 m hoogte."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Geluidproductieplafondobject.geluidproductieplafond (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject/geluidproductieplafond>
   a skos:Concept ;
   skos:prefLabel "geluidproductieplafond"@nl ;
   rdfs:label "geluidproductieplafond" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject> ;
   dct:created "07-04-2020" ;
   skos:definition '''De door het bevoegd gezag vastgestelde maximaal toegestane jaargemiddelde geluidbelasting (Lden) in dB op een referentiepunt over de periode van een etmaal met één cijfer achter de komma.'''@nl ;
   skos:note "\n                              Lden staat voor Level day evening night.\n                              Deze attribuutsoort is van toepassing op de domeinen: industrie, spoor en weg.\n                              Sommige domeinen kennen aanvullende GPP-waarden. Deze worden als aparte attribuutsoort opgenomen binnen dit object.\n                           "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Geluidproductieplafondobject.tijdelijkeOntheffingswaarde (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject/tijdelijkeOntheffingswaarde>
   a skos:Concept ;
   skos:prefLabel "tijdelijkeOntheffingswaarde"@nl ;
   rdfs:label "tijdelijkeOntheffingswaarde" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidproductieplafondobject> ;
   dct:created "07-04-2020" ;
   skos:definition '''Aantal dB waarmee het geldende GPP verhoogd wordt gedurende de geldigheid van de tijdelijke ontheffing met 1 cijfer achter de komma.'''@nl ;
   skos:note "Dit is geen verplicht gegeven. "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Geluidproductieplafondobject.beginTijdelijkeOntheffing (attrib) (ATTRIBUUTSOORT)
