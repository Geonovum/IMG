   dct:created "07-04-2020" ;
   skos:definition '''Identificatie van de leverancier en bronhouder van een \"Geluidgegevenscollectie\".'''@nl ;
.

# Construct: IMGeluid Algemeen::HerkomstCollectie.bronhouder (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/HerkomstCollectie/bronhouder>
   a skos:Concept ;
   skos:prefLabel "bronhouder"@nl ;
   rdfs:label "bronhouder" ;
