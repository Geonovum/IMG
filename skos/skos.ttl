   dct:source "NEN3610" ;
.

# Construct: IMGeluid Algemeen::Geluidgegevenscollectie.jaar (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidgegevenscollectie/jaar>
   a skos:Concept ;
   skos:prefLabel "jaar"@nl ;
   rdfs:label "jaar" ;
   skos:inScheme begrippenkader:IMG ;
