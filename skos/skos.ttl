# Construct: IMGeluid Algemeen::FlyoverZijkant (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant>
   a skos:Concept ;
   skos:prefLabel "FlyoverZijkant"@nl ;
   rdfs:label "FlyoverZijkant" ;
   dct:created "2022-07-08"^^xsd:date ;
   dct:modified "2022-07-11"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidoverdrachtobject> ;
   skos:definition '''Zijkant van een fly-over.'''@nl ;
   skos:note "De zijkant van een fly-over is een Geluidoverdrachtobject en lijkt akoestisch op een Geluidscherm. Sommige eigenschappen zijn echter anders en daarom is een aparte klasse opgenomen in het model."@nl ;
.

# Construct: IMGeluid Algemeen::FlyoverZijkant.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   rdfs:label "geometrie" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant> ;
   dct:created "07-04-2020" ;
   skos:definition '''Als 3d-lijn gemodelleerde meetkundige representatie van de onderkant van een Flyoverzijkant.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::FlyoverZijkant.reflectiefactorLinks (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant/reflectiefactorLinks>
   a skos:Concept ;
   skos:prefLabel "reflectiefactorLinks"@nl ;
   rdfs:label "reflectiefactorLinks" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant> ;
   dct:created "07-04-2020" ;
   skos:definition '''De reflectiefactor van de door de linkerzijde van de FlyoverZijkant gereflecteerde geluidsenergie per octaafband.'''@nl ;
   skos:note "Wanneer er gesproken wordt over links en rechts, dan is dit relatief aan de digitaliseringsrichting van de lijn. Om te bepalen wat de linker en rechter kant is, kan je met de digitaliseringsrichting mee over de lijn lopen. Aan je linkerhand bevindt zich dan de linkerzijde van de fly-over."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::FlyoverZijkant.reflectiefactorRechts (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant/reflectiefactorRechts>
   a skos:Concept ;
   skos:prefLabel "reflectiefactorRechts"@nl ;
   rdfs:label "reflectiefactorRechts" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant> ;
   dct:created "07-04-2020" ;
   skos:definition '''De reflectiefactor van de door de rechterzijde van de FlyoverZijkant gereflecteerde geluidsenergie per octaafband.'''@nl ;
   skos:note "Wanneer er gesproken wordt over links en rechts, dan is dit relatief aan de digitaliseringsrichting van de lijn. Om te bepalen wat de linker en rechter kant is, kan je met de digitaliseringsrichting mee over de lijn te lopen. Aan je rechterhand bevindt zich dan de rechterzijde van de fly-over."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::FlyoverZijkant.hoogte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/FlyoverZijkant/hoogte>
