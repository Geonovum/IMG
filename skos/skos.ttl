   dct:created "2019-11-20"^^xsd:date ;
   dct:modified "2021-06-24"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidoverdrachtobject> ;
   dct:created "07-04-2020" ;
   skos:definition '''Een geluidgoot of geluidafbuiger is een experimentele geluidsreducerende maatregel langs (spoor)wegen.'''@nl ;
   skos:note "\n                        Een diffractor is een betonnen constructie met daarin holtes die parallel aan het wegdek lopen (resonatoren), waardoor geluid geabsorbeerd wordt en vanwege verschillen in geluidsdruk de geluidsgolven naar boven worden gericht.\n                     "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Diffractor.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   rdfs:label "geometrie" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor> ;
   dct:created "07-04-2020" ;
   skos:definition '''Als 3d-lijn gemodelleerde meetkundige representatie van de middellijn van een diffractor of geluidgoot.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Diffractor.diffractoreffect (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor/diffractoreffect>
   a skos:Concept ;
   skos:prefLabel "diffractoreffect"@nl ;
   rdfs:label "diffractoreffect" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor> ;
   dct:created "07-04-2020" ;
   skos:definition '''De fractie van de door de geluidgoot/-afbuiger gereflecteerde geluidsenergie per octaafband.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Diffractor.breedte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor/breedte>
   a skos:Concept ;
   skos:prefLabel "breedte"@nl ;
   rdfs:label "breedte" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor> ;
   dct:created "07-04-2020" ;
   skos:definition '''De breedte in meters van de diffractor, gezien vanuit de geluidbron (weg/spoor)kortste afmeting van een geluidbeperkende voorziening. '''@nl ;
   skos:note "Deze waarde wordt alleen bij de berekening met diffractor gebruikt. De gebruiker dient het midden van de diffractor te modelleren. De bodem onder een diffractor wordt in de berekening altijd als hard verondersteld! Eventuele andere bodemfactoren worden dus ter plekke van de diffractor niet gebruikt."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Diffractor.statusZwevend (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor/statusZwevend>
   a skos:Concept ;
   skos:prefLabel "statusZwevend"@nl ;
   rdfs:label "statusZwevend" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Diffractor> ;
   dct:created "07-04-2020" ;
   skos:definition '''Indicator voor de aan- of afwezigheid van een doorgang onder het afschermende object.'''@nl ;
   skos:note "Het object zit niet vast aan de grond. Hiermee is het mogelijk een onderdoorgang of luifel te modelleren. Met de optie Zwevend object kan een doorgang onder de diffractor worden gemodelleerd. De maaiveldhoogte van het item wordt dan beschouwd als de onderzijde van het item."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Kunstwerk (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk>
   a skos:Concept ;
   skos:prefLabel "Kunstwerk"@nl ;
   rdfs:label "Kunstwerk" ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2020-09-02"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidoverdrachtobject> ;
   skosthes:narrowerGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug> ;
    skosthes:narrowerGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Overkapping> ;
    skosthes:narrowerGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Tunnel> ;
    skosthes:narrowerGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Tunnelbak> ;
   dct:created "07-04-2020" ;
   skos:definition '''Een civiel-technisch werk voor de infrastructuur van wegen, water, spoorbanen, waterkeringen en/of leidingen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Kunstwerk.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   rdfs:label "geometrie" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Als 3D of 2D vlak gemodelleerde meetkundige representatie van een kunstwerk.'''@nl ;
   skos:note "\n                              Hierbij gaat het specifiek om een brug, een overkapping, een tunnelbak of een tunnel.\n                           "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Brug (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug>
   a skos:Concept ;
   skos:prefLabel "Brug"@nl ;
   rdfs:label "Brug" ;
   dct:created "2020-01-22"^^xsd:date ;
   dct:modified "2023-09-14"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Kunstwerk over een watervlakte of waterloop, bestaande uit een brugdek gesteund door pijlers en/of landhoofden.'''@nl ;
   skos:note "Dit object is voor de berekening van het GPP op twee manieren relevant:\\n\n                        Het bepaalt waar de brugtoeslag geldt\n                        Als het een betonnen brug is, geldt de brug als een reflecterend bodemvlak op hoogte, met z-waarde t.o.v. N.A.P. afgeleid van spoorhoogte (spoorhoogte minus 20cm).\n                     "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Brug.geluidtoeslag (attrib) (GEGEVENSGROEP)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug/geluidtoeslag>
   a skos:Concept ;
   skos:prefLabel "geluidtoeslag"@nl ;
   rdfs:label "geluidtoeslag" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug> ;
   dct:created "07-04-2020" ;
   skos:definition '''Het verschil tussen de emissie van de door het kunstwerk beïnvloede bronnen en dezelfde bronnen zonder de invloed van het kunstwerk. Per spoorvoertuigcategorie kan een toeslag per octaafband worden opgenomen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Brug.indicatieToeslag (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug/indicatieToeslag>
   a skos:Concept ;
   skos:prefLabel "indicatieToeslag"@nl ;
   rdfs:label "indicatieToeslag" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Brug> ;
   dct:created "07-04-2020" ;
   skos:definition '''Attribuutsoort die aangeeft of een toeslag geldt. '''@nl ;
   skos:note "\n                              Wanneer deze waarde 1 is dan is de brug van staal en geldt de toeslag.\n                              Als de waarde 0 is, is de brug van beton en geldt geen toeslag.\n                           "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Overkapping (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Overkapping>
   a skos:Concept ;
   skos:prefLabel "Overkapping"@nl ;
   rdfs:label "Overkapping" ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2022-06-15"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Geluidoverdrachtsobject met tegenhoudende en absorberende werking, dat zich typisch boven een Spoordeel bevind.'''@nl ;
   skos:note "Dit gegevens is akoestisch relevant voor de berekening van het GPP, maar indien overkappingszijwanden ontbreken is onbekend wat het effect van de overkapping is. Indien er wel overkappingszijwanden zijn, in hoeverre verschilt de combinatie van objecten dan van een tunnel?"@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Tunnel (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Tunnel>
   a skos:Concept ;
   skos:prefLabel "Tunnel"@nl ;
   rdfs:label "Tunnel" ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2020-09-02"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Onderdeel van een kunstmatig aangelegde, kokervormige onderdoorgang dat essentieel is voor de constructie.'''@nl ;
   skos:note "Alle Spoordelen die binnen dit vlakken vallen worden op emissiewaarde  \"0\" gezet. In tegenstelling tot de andere infraobjecten wordt voor een tunnel zelf geen onderscheid gemaakt tussen, bodem, zijwand en overkapping. De tunnel sluit het geluid namelijk volledig af, dus de ligging van de tunnel is volstaat."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Tunnelbak (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Tunnelbak>
   a skos:Concept ;
   skos:prefLabel "Tunnelbak"@nl ;
   rdfs:label "Tunnelbak" ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2022-07-01"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Kunstwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Het bodemvlak (vloer) van de niet overkapte helling die een tunnel verbindt met het maaiveld.'''@nl ;
   skos:note "\n                        Dit betreft het bodemvlak van de tunnelbak.\n                        De wanden van de tunnelbak behoren niet tot de geometrie van dit object en worden als Geluidschermdeel met schermtype=tunnelbakwand gemodelleerd.\n                     "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Tunnelbak.reflectiefactor (attrib) (ATTRIBUUTSOORT)
