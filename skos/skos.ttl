   rdfs:label "ProfieltypeGeluidscherm" ;
   skos:notation "ProfieltypeGeluidscherm"^^xsd:string ;
   dct:created "2019-07-22"^^xsd:date ;
   dct:modified "2021-07-12"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skos:definition '''Vormaanduiding van het type geluidscherm'''@nl ;
   skos:member <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/scherp> ;
   skos:member <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/stomp> ;
   skos:member <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/perron> ;
   skos:member <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/middenberm> ;
   skos:member <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/t-top> ;
.

# Construct: IMGeluid Algemeen::ProfieltypeGeluidscherm.scherp (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/scherp>
   a skos:Concept ;
   skos:prefLabel "scherp"@nl ;
   rdfs:label "scherp" ;
   skos:notation "scherp"^^xsd:string ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm> ;
   skos:definition '''Alle gebouwen, dunne wanden waarvan de hoek met verticaal = 20°, grondlichamen met 0° = T = 70°, alle grondlichamen met daarop een dunne wand, als de totale constructiehoogte minder dan twee maal de hoogte van die wand is, of als de wand hoger is dan 3,5 m, bij toepassing van een schermtop en waarvan het effect met de correctieterm CT in rekening wordt gebracht.'''@nl ;
.

# Construct: IMGeluid Algemeen::ProfieltypeGeluidscherm.stomp (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/stomp>
   a skos:Concept ;
   skos:prefLabel "stomp"@nl ;
   rdfs:label "stomp" ;
   skos:notation "stomp"^^xsd:string ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm> ;
   skos:definition '''Alle randen van weglichamen in ophoging, randen van wegen op een viaduct, alle grondlichamen met daarop een dunne wand, als de totale constructiehoogte meer bedraagt dan twee maal de hoogte van die wand en de wand niet hoger is dan 3,5 m en grondlichamen met 70° < T = 165°'''@nl ;
.

# Construct: IMGeluid Algemeen::ProfieltypeGeluidscherm.perron (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/ProfieltypeGeluidscherm/perron>
   a skos:Concept ;
