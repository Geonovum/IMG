   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk = obstacle (OBJECTTYPE)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk>
   a skos:Concept ;
   skos:prefLabel "Bouwwerk"@nl ;
   rdfs:label "Bouwwerk" ;
   dct:created "2019-09-12"^^xsd:date ;
   dct:modified "2020-09-15"^^xsd:date ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderGeneric <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Geluidoverdrachtobject> ;
   dct:created "07-04-2020" ;
   skos:definition '''Geluidoverdrachtobject dat de absorberende en reflecterende akoestische werking van een statisch fysiek object modelleert.'''@nl ;
   skos:note "\n                        Een Bouwwerk kan bij akoestisch onderzoek voor industrieterreinen worden gebruikt, om de reflecterende en absorberende werking van een fysiek object zoals een gebouw te modelleren.\n                        In de reken- en meetvoorschriften wordt er gesproken van een Gebouw in plaats van Bouwwerk. In IMGeluid hebben we ervoor gekozen de naam Bouwwerk te gebruiken, omdat dit object niet per definitie een Gebouw hoeft te zijn zoals dit begrip gedefinieerd is in andere registraties.\n                     "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk.geometrie (attrib) = geometry (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   rdfs:label "geometrie" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Als 3D-vlak gemodelleerde meetkundige horizontaal platte representatie van het dak van een bouwwerk.'''@nl ;
   skos:note "\n                              De z-coördinaat representeert een hoogte die akoestische representatief is voor dat Bouwwerk.\n                              Bij het modelleren van een complex bouwwerk mogen meerdere Bouwwerk objecten worden gebruikt.\n                           "@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk.maaiveld (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk/maaiveld>
   a skos:Concept ;
   skos:prefLabel "maaiveld"@nl ;
   rdfs:label "maaiveld" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''3D-geometrie die evenveel punten bevat als het attribuut \'geometrie\' met dezelde x- en y- coördinaten. De z-coördinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Bouwwerk op het maaiveld.\n                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk.reflectiefactor (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk/reflectiefactor>
   a skos:Concept ;
   skos:prefLabel "reflectiefactor"@nl ;
   rdfs:label "reflectiefactor" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk> ;
   skos:definition '''De fractie van de door het geveloppervlak gereflecteerde geluidenergie per octaafband.'''@nl ;
   skos:note "De reflectiefactor wordt per octaafband ingevoerd."@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk.profielcorrectie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk/profielcorrectie>
   a skos:Concept ;
   skos:prefLabel "profielcorrectie"@nl ;
   rdfs:label "profielcorrectie" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''De profielcorrectie geeft de mogelijkheid de schermwerking in alle frequenties te verlagen bij flauwe tophoeken van daken, taluds of wallen met de ingevoerde waarde.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid Algemeen::Bouwwerk.isCilindrisch (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk/isCilindrisch>
   a skos:Concept ;
   skos:prefLabel "isCilindrisch"@nl ;
   rdfs:label "isCilindrisch" ;
   skos:inScheme begrippenkader:IMG ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/id/begrippenkader/IMG/Bouwwerk> ;
   dct:created "07-04-2020" ;
   skos:definition '''Geeft aan of een Bouwwerk cilindervormig is.'''@nl ;
   skos:note "\n                              Wanneer een gebouw een cilinder is worden andere absorptiewaardes toegekend.\n                              Hoe met cilindrisch gaat worden omgegeaan is nog niet zeker. Wel is duidelijk geworden dat niet elk rekenpakket hier hetzelfde mee omgaat.\n                           "@nl ;
   dct:source "IMGeluid" ;
.

