# Construct: IMGeluid::Geluidemissieobject (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject>
   a skos:Concept ;
   skos:prefLabel "Geluidemissieobject"@nl ;
   dct:created "2020-01-07"^^xsd:date ;
   dct:modified "2023-06-08"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/GeluidgegevenscollectieElement> ;
   skos:definition '''Abstractie van alle volgens wet- en regelgeving relevante infrastructurele- en industrieterrein-objecten uit de werkelijkheid die geluid produceren.'''@nl ;
   skos:scopeNote '''Een geluidemissieobject heeft verschillende functies:\n
                        Het kan een object zijn dat gebruikt is voor de bepaling van de hoogte van een geluidproductieplafond of basisgeluidemissie;
                        Het kan ook gebruikt zijn in de berekening van de monitoringswaarde in van een bepaald jaar. Indien een bevoegd gezag ervoor kiest om de emissieobjecten die ten grondslag liggen aan de monitoringsberekening mee te leveren, is het noodzakelijk om deze te koppelen aan het monitoringsjaar waarop ze betrekking hebben;
                        Het object kan gebruikt worden gebruikt voor het aanleveren van prognose gegevens.  Het Geluidgegevenscollectie.type is dan \"prognose\".
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidemissieobject.naam (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/naam>
   a skos:Concept ;
   skos:prefLabel "naam"@nl ;
   skos:altLabel "naam (Geluidemissieobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Korte naam voor het Geluidemissieobject.'''@nl ;
   skos:scopeNote '''Naam toevoegen is optioneel. Alleen toevoegen wanneer deze informatie van toegevoegde waarde is voor een gebruiker van het geluidregister. '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidemissieobject.omschrijving (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/omschrijving>
   a skos:Concept ;
   skos:prefLabel "omschrijving"@nl ;
   skos:altLabel "omschrijving (Geluidemissieobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Meer uitgebreide omschrijving van een geluidemissieobject als aanvulling op de naam.'''@nl ;
   skos:scopeNote '''Omschrijving toevoegen is optioneel. Alleen toevoegen wanneer deze informatie van toegevoegde waarde is voor een gebruiker van het geluidregister.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidemissieobject.situatieVan (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/situatieVan>
   a skos:Concept ;
   skos:prefLabel "situatieVan"@nl ;
   skos:altLabel "situatieVan (Geluidemissieobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Het jaartal van de situatie waarop het emissieobject betrekking heeft.'''@nl ;
   skos:scopeNote '''
                              Met situatie bedoelen we een onderdeel van de akoestisch werkelijkheid, zoals gemodelleerd conform de rekenregels voor akoestisch onderzoek.
                           \n
                              Wanneer het typeGegevenscollectie geen \'vaststelling\' betreft, is het invullen van Geluidgegevenscollectie.jaar voldoende.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie>
   a skos:Concept ;
   skos:prefLabel "GeluidbronIndustrie"@nl ;
   dct:created "2019-09-11"^^xsd:date ;
   dct:modified "2023-05-24"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Geluidafstralend toestel, apparaat, gebouw of activiteit, dan wel een combinatie hiervan, binnen een inrichting of industrieterrein.'''@nl ;
   skos:scopeNote '''Dit object wordt zowel voor binnen het domein GPP-industrie als GPP-spoor gebruikt. In dat laatste geval alleen voor stilstaande treinen op emplacementen/opstelterreinen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (GeluidbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie> ;
   skos:definition '''Als 3D-punt gemodelleerde meetkundige representatie van een geluidbronindustrie.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie.reflectiepuntHoogte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/reflectiepuntHoogte>
   a skos:Concept ;
   skos:prefLabel "reflectiepuntHoogte"@nl ;
   skos:altLabel "reflectiepuntHoogte (GeluidbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie> ;
   skos:definition '''Hoogte van een punt (in meters met 1 cijfer achter de komma) ten opzichte van NAP waarop eerste reflectie van een GeluidbronIndustrie op een oppervlak plaatsvindt.'''@nl ;
   skos:scopeNote '''
                              Voor een GeluidbronIndustrie binnen het industriedomein, is het relevant om te weten wat het hoogteverschil is tussen de bron en het eerste punt waarop reflectie zal plaatsvinden.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie.relevanteBronsterkte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/relevanteBronsterkte>
   a skos:Concept ;
   skos:prefLabel "relevanteBronsterkte"@nl ;
   skos:altLabel "relevanteBronsterkte (GeluidbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie> ;
   skos:definition '''Geluidsvermogensniveau van een denkbeeldige bron, gelegen in het centrum van de werkelijke geluidsbron, die in de richting van het geluidimmissiepunt dezelfde geluiddrukniveaus veroorzaakt als de werkelijke geluidbron.'''@nl ;
   skos:scopeNote '''De relevante geluidbronsterkte wordt gebruikt om de geluidemissie uit te drukken per Octaafband in dB(A). dB(A) wordt gebruikt om aan te geven dat de A filter is toegepast. De A filter is een correctie op de decibel-schaal naar menselijk gehoor.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie.uitstralingsrichting (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/uitstralingsrichting>
   a skos:Concept ;
   skos:prefLabel "uitstralingsrichting"@nl ;
   skos:altLabel "uitstralingsrichting (GeluidbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie> ;
   skos:definition '''Richting waarop GeluidbronIndustrie emissie uitstraalt.'''@nl ;
   skos:scopeNote '''
                              De uitstralingsrichting wordt bepaald door een \'openingshoek\' en een \'uitstralingsrichting\'.
                           \n
                              De uitstralingsrichting is: Richting waar emissie naar uitstraalt.
                           \n
                              De openingshoek is: Opening van de hoek van emissie-uitstraling met als midden de uitstralingsrichting.
                              Deze hoeken worden uitgedrukt in graden volgens de kompasrichtingen.
                              Wanneer geen uitstralingsrichting bekend is, wordt default 360 graden ingevuld bij de openingshoek van de UitstralingsrichtingWaarde en 0 graden bij de uitstralingsrichting.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidbronIndustrie.bedrijfsduurcorrectie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/bedrijfsduurcorrectie>
   a skos:Concept ;
   skos:prefLabel "bedrijfsduurcorrectie"@nl ;
   skos:altLabel "bedrijfsduurcorrectie (GeluidbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/GeluidbronIndustrie> ;
   skos:definition '''Bedrijfsduurcorrectie in dB per dagdeel.'''@nl ;
   skos:scopeNote '''Bij de bedrijvigheid op een industrieterrein gaan we uit van de jaargemiddelde bedrijfssituatie. Jaargemiddelde bedrijfssituatie: De toestand die jaargemiddeld optreedt qua geluidproductie van de activiteiten  in de te beschouwen etmaalperiode.
 \n
                              De etmaalperiode (ook wel: dagdeel) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.
                              Dit attribuut zal in totaal 3 keer moeten worden opgenomen per GeluidsbronIndustrie
                           \nEtmaalperioden:\n
                              Dagperiode (7.00-19.00 uur)
                              Avondperiode (19.00-23.00 uur)
                              Nachtperiode (23.00-7.00 uur)
                           '''@nl ;
   dct:source "IMGeluid" ;
.

