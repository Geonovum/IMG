   dct:created "2019-11-13"^^xsd:date ;
   dct:modified "2022-03-15"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/GeluidgegevenscollectieElement> ;
   skos:definition '''Een verzameling van geluidcontouren met één gemeenschappelijke geluidbron'''@nl ;
   skos:scopeNote '''Door het invoeren van de GeluidcontourSet, kunnen attributen die per set gelden daar aan gekoppeld worden. Attributen die per geluidcontour gelden, blijven bij de geluidcontour. Daarmee wordt minder informatie dubbel opgeslagen.'''@nl ;
   dct:source "IMGeluid" ;
.

