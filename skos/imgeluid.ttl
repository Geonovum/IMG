   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Identificatie van de leverancier en bronhouder van een \"Geluidgegevenscollectie\".'''@nl ;
.

# Construct: IMGeluid::HerkomstCollectie.bronhouder (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/bronhouder>
   a skos:Concept ;
   skos:prefLabel "bronhouder"@nl ;
   skos:altLabel "bronhouder (HerkomstCollectie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/HerkomstCollectie> ;
   skos:definition '''Unieke identificatie van de bronhouder van de \"Geluidgegevenscollectie\".'''@nl ;
   skos:scopeNote '''Een Industrieterrein kan over gemeentegrenzen heel vallen. Een Industrieterrein kan dus meer bevoegd gezag hebben, daarom bestaat de optie om meer dan 1 bronhouder toe te voegen.'''@nl ;
   dct:source "IMGeluid" ;
.

