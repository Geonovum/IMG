.

# Construct: IMGeluid::Hoogtelijn (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Hoogtelijn>
   a skos:Concept ;
   skos:prefLabel "Hoogtelijn"@nl ;
   dct:created "2019-07-01"^^xsd:date ;
   dct:modified "2022-06-15"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Breuklijn om het hoogteverloop van het terrein te modelleren'''@nl ;
   skos:scopeNote '''Het object Hoogtelijn is optioneel. Het is niet verplicht om hoogtelijnen in de berekening van het GPP gebruiken, behalve als deze binnen de grenzen van een industrieterrein ligt.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Hoogtelijn.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Hoogtelijn)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Hoogtelijn> ;
   skos:definition '''De als een 3D-lijn gemodelleerde meetkundige representatie van een hoogtelijn.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Hoogtelijn.hoogtelijntype (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/hoogtelijntype>
   a skos:Concept ;
   skos:prefLabel "hoogtelijntype"@nl ;
   skos:altLabel "hoogtelijntype (Hoogtelijn)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Hoogtelijn> ;
   skos:definition '''Classificatie van het soort breuklijn.'''@nl ;
   skos:scopeNote '''IMGeluid'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bodemvlak (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Bodemvlak>
   a skos:Concept ;
   skos:prefLabel "Bodemvlak"@nl ;
   dct:created "2019-06-26"^^xsd:date ;
   dct:modified "2024-08-14"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Object dat de geluid-absorberende werking van een vlak hardere of zachtere bodem simuleert.'''@nl ;
.

# Construct: IMGeluid::Bodemvlak.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Bodemvlak)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bodemvlak> ;
   skos:definition '''De als een 2D vlak gemodelleerde meetkundige representatie van een akoestisch bodemvlak.'''@nl ;
   skos:scopeNote '''Een bodemvlakgeometrie heeft geen hoogte, want is 2D.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bodemvlak.absorptiefractie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/absorptiefractie>
   a skos:Concept ;
   skos:prefLabel "absorptiefractie"@nl ;
   skos:altLabel "absorptiefractie (Bodemvlak)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bodemvlak> ;
   skos:definition '''Aanduiding voor de akoestische hardheid van de bodem.'''@nl ;
   skos:scopeNote '''Aanduiding voor de akoestische hardheid van de bodem.absorptiefractie: hard (0), zacht (1) en half (0,5).'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk = obstacle (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Bouwwerk>
   a skos:Concept ;
   skos:prefLabel "Bouwwerk"@nl ;
   dct:created "2019-09-12"^^xsd:date ;
   dct:modified "2020-09-15"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Geluidoverdrachtobject dat de absorberende en reflecterende akoestische werking van een statisch fysiek object modelleert.'''@nl ;
   skos:scopeNote '''
                        Een Bouwwerk kan bij akoestisch onderzoek voor industrieterreinen worden gebruikt, om de reflecterende en absorberende werking van een fysiek object zoals een gebouw te modelleren.
                        In de reken- en meetvoorschriften wordt er gesproken van een Gebouw in plaats van Bouwwerk. In IMGeluid hebben we ervoor gekozen de naam Bouwwerk te gebruiken, omdat dit object niet per definitie een Gebouw hoeft te zijn zoals dit begrip gedefinieerd is in andere registraties.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk.geometrie (attrib) = geometry (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Bouwwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bouwwerk> ;
   skos:definition '''Als 3D-vlak gemodelleerde meetkundige horizontaal platte representatie van het dak van een bouwwerk.'''@nl ;
   skos:scopeNote '''
                              De z-coördinaat representeert een hoogte die akoestische representatief is voor dat Bouwwerk.
                              Bij het modelleren van een complex bouwwerk mogen meerdere Bouwwerk objecten worden gebruikt.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk.maaiveld (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/maaiveld>
   a skos:Concept ;
   skos:prefLabel "maaiveld"@nl ;
   skos:altLabel "maaiveld (Bouwwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bouwwerk> ;
   skos:definition '''3D-geometrie die evenveel punten bevat als het attribuut \'geometrie\' met dezelde x- en y- coördinaten. De z-coördinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Bouwwerk op het maaiveld.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk.reflectiefactor (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/reflectiefactor>
   a skos:Concept ;
   skos:prefLabel "reflectiefactor"@nl ;
   skos:altLabel "reflectiefactor (Bouwwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bouwwerk> ;
   skos:definition '''De fractie van de door het geveloppervlak gereflecteerde geluidenergie per octaafband.'''@nl ;
   skos:scopeNote '''De reflectiefactor wordt per octaafband ingevoerd.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk.profielcorrectie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/profielcorrectie>
   a skos:Concept ;
   skos:prefLabel "profielcorrectie"@nl ;
   skos:altLabel "profielcorrectie (Bouwwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bouwwerk> ;
   skos:definition '''De profielcorrectie geeft de mogelijkheid de schermwerking in alle frequenties te verlagen bij flauwe tophoeken van daken, taluds of wallen met de ingevoerde waarde.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Bouwwerk.isCilindrisch (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/isCilindrisch>
   a skos:Concept ;
   skos:prefLabel "isCilindrisch"@nl ;
   skos:altLabel "isCilindrisch (Bouwwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Bouwwerk> ;
   skos:definition '''Geeft aan of een Bouwwerk cilindervormig is.'''@nl ;
   skos:scopeNote '''
                              Wanneer een gebouw een cilinder is worden andere absorptiewaardes toegekend.
                              Hoe met cilindrisch gaat worden omgegeaan is nog niet zeker. Wel is duidelijk geworden dat niet elk rekenpakket hier hetzelfde mee omgaat.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Procesinstallatiegebied (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Procesinstallatiegebied>
   a skos:Concept ;
   skos:prefLabel "Procesinstallatiegebied"@nl ;
