   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/HerkomstCollectie> ;
   skos:definition '''Unieke identificatie van de leverancier van de Geluidgegevenscollectie.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidtoeslag (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Geluidtoeslag>
   a skos:Concept ;
   skos:prefLabel "Geluidtoeslag"@nl ;
   dct:created "2019-11-11"^^xsd:date ;
   dct:modified "2024-08-14"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Verzameling van geluidtoeslaggegevens van treinvoertuigen per octaafband die zich over een brug verplaatsen.'''@nl ;
   skos:scopeNote '''
                        Een brugwand is een zwevend scherm waardoor ook geluidimmissies van onderliggende sporen goed berekend kunnen worden. Er moet in zo een geval nader onderzoek gedaan worden naar de geluiduitstraling van het kunstwerk.
                     '''@nl ;
.

# Construct: IMGeluid::Geluidtoeslag.toeslag (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/toeslag>
   a skos:Concept ;
   skos:prefLabel "toeslag"@nl ;
   skos:altLabel "toeslag (Geluidtoeslag)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidtoeslag> ;
   skos:definition '''De emissietoeslag per octaafband voor stalen kunstwerken, gebaseerd op de methode zoals omschreven in de Omgevingsregeling.'''@nl ;
   skos:scopeNote '''Indien een dergelijke waarde niet voorhanden is, wordt er gebruik gemaakt van een brugemissietoeslag (voor elke spoorvoertuigcategorie en octaafband) die afhankelijk is van het type bovenbouwconstructie.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidtoeslag.spoorvoertuigcategorie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/spoorvoertuigcategorie>
   a skos:Concept ;
   skos:prefLabel "spoorvoertuigcategorie"@nl ;
   skos:altLabel "spoorvoertuigcategorie (Geluidtoeslag)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidtoeslag> ;
   skos:definition '''Categorie-indeling van spoorvoertuigtypen.'''@nl ;
   skos:scopeNote '''Zie de Omgevingsregeling voor een nadere omschrijving.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/BovenbouwgegevensSpoor>
   a skos:Concept ;
   skos:prefLabel "BovenbouwgegevensSpoor"@nl ;
   dct:created "2019-12-18"^^xsd:date ;
   dct:modified "2023-05-25"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''De constructie die het dragen en geleiden van spoorvoertuigen verzorgt en gelegen is op de onderbouw (het geheel van aardebaan en kunstwerken. Dit is de dragende constructie voor de bovenbouw).'''@nl ;
   skos:scopeNote '''Het geheel van spoorconstructie: (dikte van) ballastbed, dwarsligger, bevestiging, voegen en railruwheid. Er bestaan 2 bovenbouwconstructies, te weten:\n
                        De ballastconstructie; deze bestaat uit ballast, dwarsliggers, spoorstaven en wissels alsmede het bijbehorende bevestigingsmateriaal;
                        Ballastloze constructie; deze bestaat uit: een doorlopende plaat van beton, spoorstaven, bevestigingsmiddelen al dan niet gevat in een gietmassa. Komt o.a. voor bij tankinstallatie, wasinstallaties en kunstwerken
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor.spoorstaafruwheidMiddelsCategorie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/spoorstaafruwheidMiddelsCategorie>
   a skos:Concept ;
   skos:prefLabel "spoorstaafruwheidMiddelsCategorie"@nl ;
   skos:altLabel "spoorstaafruwheidMiddelsCategorie (BovenbouwgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/BovenbouwgegevensSpoor> ;
   skos:definition '''Indicatie van ruwheid van het spoordeel middels een catagorie.\nAls de ruwheid van de spoorstaaf met een categorie is aangegeven dan is de relatie spoorstaafruwheidMiddelsMeting leeg.'''@nl ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor.bovenbouwcode (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/bovenbouwcode>
   a skos:Concept ;
   skos:prefLabel "bovenbouwcode"@nl ;
   skos:altLabel "bovenbouwcode (BovenbouwgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/BovenbouwgegevensSpoor> ;
   skos:definition '''Categorie-indeling van de bovenbouw.'''@nl ;
   skos:scopeNote '''Een Spoordeel kan verschillende bovenbouwcodes hebben. De in te voeren bovenbouwcode is afhankelijk van de boring, dwarsliggertype, spoorstaafbevestiging, ballastdikte en de eventuele aanwezigheid van raildempers. De combinatie van voorgaande factoren resulteert in een bijbehorende bovenbouwklasse.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor.spoorstaafonderbreking (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/spoorstaafonderbreking>
   a skos:Concept ;
   skos:prefLabel "spoorstaafonderbreking"@nl ;
   skos:altLabel "spoorstaafonderbreking (BovenbouwgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/BovenbouwgegevensSpoor> ;
   skos:definition '''Index die een indicatie geeft van de aanwezigheid van onderbrekingen in de geprofileerde ijzeren staaf die onderdeel is van een spoordeel.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor.spoorstaafruwheidMiddelsMeting (assoc) ()
<http://definities.geostandaarden.nl/img/id/concept/spoorstaafruwheidMiddelsMeting>
   a skos:Concept ;
