   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Gebied dat een dempende invloed heeft op de geluidemissie van bronnen. '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Procesinstallatiegebied.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Procesinstallatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Procesinstallatiegebied> ;
   skos:definition '''Als 3D-vlak gemodelleerde meetkundige representatie van een procesinstallatiegebied.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Procesinstallatiegebied.maaiveld (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/maaiveld>
   a skos:Concept ;
   skos:prefLabel "maaiveld"@nl ;
   skos:altLabel "maaiveld (Procesinstallatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Procesinstallatiegebied> ;
   skos:definition '''3D-geometrie die evenveel punten bevat als het attribuut \'geometrie\' met dezelde x- en y- coördinaten. De z-coördinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Procesinstallatiegebeid  op het maaiveld.
                           '''@nl ;
   skos:scopeNote '''
                              Uit het verschil van de z-coördinaten tussen de geometrie van een Procesinstallatiegebied en de z-coördinaten in maaveld is de hoogte van een Procesinstallatiegebied t.o.v. het maaiveld te bepalen,
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Procesinstallatiegebied.demping (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/demping>
   a skos:Concept ;
   skos:prefLabel "demping"@nl ;
   skos:altLabel "demping (Procesinstallatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Procesinstallatiegebied> ;
   skos:definition '''Dempingswaarde voor een Procesinstallatiegebied per octaafband, per meter dat geluid door procesinstallatiegebied aflegt.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Procesinstallatiegebied.maxDemping (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/maxDemping>
   a skos:Concept ;
   skos:prefLabel "maxDemping"@nl ;
   skos:altLabel "maxDemping (Procesinstallatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Procesinstallatiegebied> ;
   skos:definition '''Maximale waarde in dB die attribuutsoort demping kan hebben per octaafband.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Vegetatiegebied (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Vegetatiegebied>
   a skos:Concept ;
   skos:prefLabel "Vegetatiegebied"@nl ;
   dct:created "2019-09-17"^^xsd:date ;
   dct:modified "2020-09-02"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Overdracht object dat een gebied afbakent, waarin door vegetatie de overdracht van geluid wordt beperkt met een vast waarde .'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Vegetatiegebied.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Vegetatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Vegetatiegebied> ;
   skos:definition '''Als 3D-vlak gemodelleerde meetkundige representatie van een vegetatiegebied.'''@nl ;
   skos:scopeNote '''
                              Voor het modelleren van een vegetatiegebied met verschillende eigenschappen mogen meerdere objecten worden gebruikt.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Vegetatiegebied.maaiveld (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/maaiveld>
   a skos:Concept ;
   skos:prefLabel "maaiveld"@nl ;
   skos:altLabel "maaiveld (Vegetatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Vegetatiegebied> ;
   skos:definition '''3D-geometrie die evenveel punten bevat als het attribuut \'geometrie\' met dezelde x- en y- coördinaten. De z-coördinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Vegetatiegebied  op het maaiveld.
                           '''@nl ;
   skos:scopeNote '''
                              Uit het verschil van de z-coördinaten tussen de geometrie van een Vegetatiegebied en onderkantVegetatiegebied is de hoogte van een Vegetatiegebied t.o.v. het maaiveld te bepalen,
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Vegetatiegebied.demping (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/demping>
   a skos:Concept ;
   skos:prefLabel "demping"@nl ;
   skos:altLabel "demping (Vegetatiegebied)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Vegetatiegebied> ;
   skos:definition '''Dempingswaarde voor een vegetatiegebied per octaafband.'''@nl ;
   skos:scopeNote '''Opties zijn hier de waarden horende bij bladverliezend OF niet bladverliezend.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Diffractor (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Diffractor>
   a skos:Concept ;
   skos:prefLabel "Diffractor"@nl ;
   dct:created "2019-11-20"^^xsd:date ;
   dct:modified "2024-08-14"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Een geluidgoot of geluidafbuiger is een experimentele geluidsreducerende maatregel langs (spoor)wegen.'''@nl ;
   skos:scopeNote '''
                        Een diffractor is een betonnen constructie met daarin holtes die parallel aan het wegdek lopen (resonatoren), waardoor geluid geabsorbeerd wordt en vanwege verschillen in geluidsdruk de geluidsgolven naar boven worden gericht.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Diffractor.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Diffractor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Diffractor> ;
   skos:definition '''Als 3d-lijn gemodelleerde meetkundige representatie van de middellijn van een diffractor of geluidgoot.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Diffractor.diffractoreffect (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/diffractoreffect>
   a skos:Concept ;
   skos:prefLabel "diffractoreffect"@nl ;
   skos:altLabel "diffractoreffect (Diffractor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Diffractor> ;
   skos:definition '''De fractie van de door de geluidgoot/-afbuiger gereflecteerde geluidsenergie per octaafband.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Diffractor.breedte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/breedte>
   a skos:Concept ;
   skos:prefLabel "breedte"@nl ;
   skos:altLabel "breedte (Diffractor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Diffractor> ;
   skos:definition '''De breedte in meters van de diffractor, gezien vanuit de geluidbron (weg/spoor)kortste afmeting van een geluidbeperkende voorziening. '''@nl ;
   skos:scopeNote '''Deze waarde wordt alleen bij de berekening met diffractor gebruikt. De gebruiker dient het midden van de diffractor te modelleren. De bodem onder een diffractor wordt in de berekening altijd als hard verondersteld! Eventuele andere bodemfactoren worden dus ter plekke van de diffractor niet gebruikt.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Diffractor.statusZwevend (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/statusZwevend>
   a skos:Concept ;
   skos:prefLabel "statusZwevend"@nl ;
   skos:altLabel "statusZwevend (Diffractor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Diffractor> ;
   skos:definition '''Indicator voor de aan- of afwezigheid van een doorgang onder het afschermende object.'''@nl ;
   skos:scopeNote '''Het object zit niet vast aan de grond. Hiermee is het mogelijk een onderdoorgang of luifel te modelleren. Met de optie Zwevend object kan een doorgang onder de diffractor worden gemodelleerd. De maaiveldhoogte van het item wordt dan beschouwd als de onderzijde van het item.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Kunstwerk (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Kunstwerk>
   a skos:Concept ;
   skos:prefLabel "Kunstwerk"@nl ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2024-08-14"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Een civiel-technisch werk voor de infrastructuur van wegen, water, spoorbanen, waterkeringen en/of leidingen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Kunstwerk.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (Kunstwerk)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Kunstwerk> ;
   skos:definition '''Als 3D of 2D vlak gemodelleerde meetkundige representatie van een kunstwerk.'''@nl ;
   skos:scopeNote '''
                              Hierbij gaat het specifiek om een brug, een overkapping, een tunnelbak of een tunnel.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Brug (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Brug>
   a skos:Concept ;
   skos:prefLabel "Brug"@nl ;
   dct:created "2020-01-22"^^xsd:date ;
   dct:modified "2024-07-10"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Kunstwerk> ;
   skos:definition '''Een brug is een vaste of beweegbare verbinding voor het verkeer over een obstakel.'''@nl ;
   skos:scopeNote '''Dit object is voor de berekening van het GPP op twee manieren relevant:\n
                        Het bepaalt waar de brugtoeslag geldt
                        Als het een betonnen brug is, geldt de brug als een reflecterend bodemvlak op hoogte, met z-waarde t.o.v. N.A.P. afgeleid van spoorhoogte (spoorhoogte minus 20cm).
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Brug.geluidtoeslag (attrib) (GEGEVENSGROEP)
<http://definities.geostandaarden.nl/img/id/concept/geluidtoeslag>
   a skos:Concept ;
   skos:prefLabel "geluidtoeslag"@nl ;
   skos:altLabel "geluidtoeslag (Brug)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Brug> ;
   skos:definition '''Het verschil tussen de emissie van de door het kunstwerk beïnvloede bronnen en dezelfde bronnen zonder de invloed van het kunstwerk. Per spoorvoertuigcategorie kan een toeslag per octaafband worden opgenomen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Brug.indicatieToeslag (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/indicatieToeslag>
   a skos:Concept ;
   skos:prefLabel "indicatieToeslag"@nl ;
   skos:altLabel "indicatieToeslag (Brug)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Brug> ;
   skos:definition '''Attribuutsoort die aangeeft of een toeslag geldt. '''@nl ;
   skos:scopeNote '''
                              Wanneer deze waarde 1 is dan is de brug van staal en geldt de toeslag.
                              Als de waarde 0 is, is de brug van beton en geldt geen toeslag.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Overkapping (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Overkapping>
   a skos:Concept ;
   skos:prefLabel "Overkapping"@nl ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2022-06-15"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Kunstwerk> ;
   skos:definition '''Geluidoverdrachtsobject met tegenhoudende en absorberende werking, dat zich typisch boven een Spoordeel bevind.'''@nl ;
   skos:scopeNote '''Dit gegevens is akoestisch relevant voor de berekening van het GPP, maar indien overkappingszijwanden ontbreken is onbekend wat het effect van de overkapping is. Indien er wel overkappingszijwanden zijn, in hoeverre verschilt de combinatie van objecten dan van een tunnel?'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Tunnel (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Tunnel>
   a skos:Concept ;
   skos:prefLabel "Tunnel"@nl ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2020-09-02"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Kunstwerk> ;
   skos:definition '''Onderdeel van een kunstmatig aangelegde, kokervormige onderdoorgang dat essentieel is voor de constructie.'''@nl ;
   skos:scopeNote '''Alle Spoordelen die binnen dit vlakken vallen worden op emissiewaarde  \"0\" gezet. In tegenstelling tot de andere infraobjecten wordt voor een tunnel zelf geen onderscheid gemaakt tussen, bodem, zijwand en overkapping. De tunnel sluit het geluid namelijk volledig af, dus de ligging van de tunnel is volstaat.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Tunnelbak (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Tunnelbak>
   a skos:Concept ;
   skos:prefLabel "Tunnelbak"@nl ;
   dct:created "2020-01-23"^^xsd:date ;
   dct:modified "2022-07-01"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Kunstwerk> ;
   skos:definition '''Het bodemvlak (vloer) van de niet overkapte helling die een tunnel verbindt met het maaiveld.'''@nl ;
   skos:scopeNote '''
                        Dit betreft het bodemvlak van de tunnelbak.
                        De wanden van de tunnelbak behoren niet tot de geometrie van dit object en worden als Geluidschermdeel met schermtype=tunnelbakwand gemodelleerd.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Tunnelbak.reflectiefactor (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/reflectiefactor>
   a skos:Concept ;
   skos:prefLabel "reflectiefactor"@nl ;
   skos:altLabel "reflectiefactor (Tunnelbak)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Tunnelbak> ;
   skos:definition '''De fractie van de door het bodemvlak van de tunnelbak gereflecteerde geluidsenergie per octaafband.'''@nl ;
   dct:source "IMGeluid" ;
.

