.

# Construct: IMGeluid::IntensiteitgegevensSpoor (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor>
   a skos:Concept ;
   skos:prefLabel "IntensiteitgegevensSpoor"@nl ;
   dct:created "2019-10-30"^^xsd:date ;
   dct:modified "2020-08-19"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Verzameling van intensiteitgegevens van treinvoertuigen die zich per etmaalperiode over een Spoordeel verplaatsen.'''@nl ;
   skos:scopeNote '''
                        Geheel van informatie over de intensiteit waarmee treinvoertuigen zich over een spoortak verplaatsen, waarbij per dagdeel het snelheidsprofiel, de intensiteit, de rijrichting, de spoorvoertuigcategorie en het treintype worden vastgelegd.
                        Het dagdeel (ook wel: etmaalperiode) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.
                     \n
                        Etmaalperioden
                     \n
                        Dagperiode (7.00-19.00 uur)
                        Avondperiode (19.00-23.00 uur)
                        Nachtperiode (23.00-7.00 uur)
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.intensiteit (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/intensiteit>
   a skos:Concept ;
   skos:prefLabel "intensiteit"@nl ;
   skos:altLabel "intensiteit (IntensiteitgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor> ;
   skos:definition '''Gemiddelde uurintensiteit per etmaalperiode, per voertuigcategorie.'''@nl ;
   skos:scopeNote '''Aantal rekeneenheden per uur in twee decimalen. Afhankelijk van het spoorvoertuigtype een locomotief, een treinstel, een rijtuig of een wagen, indien deze deel uitmaakt van het spoorvoertuigtype.\nToegestane waarden: 0,0 - 999,99'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.profieltypeSnelheid (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/profieltypeSnelheid>
   a skos:Concept ;
   skos:prefLabel "profieltypeSnelheid"@nl ;
   skos:altLabel "profieltypeSnelheid (IntensiteitgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor> ;
   skos:definition '''(Maatgevende) karakteristiek van de snelheid van de treinvoertuigen over een lengte van een spoortak.'''@nl ;
   skos:scopeNote '''Er kan sprake zijn van doorgaand, stoppend of rangerend materieel.
Alleen op spooremplacementen kan sprake zijn van rangerend materieel. Spooremplacementen zijn echter niet als zodanig (apart) gemodelleerd.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.spoorvoertuigcategorie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/spoorvoertuigcategorie>
   a skos:Concept ;
