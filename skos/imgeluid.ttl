   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor> ;
   skos:definition '''Categorie-indeling van spoorvoertuigtypen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.dagdeel (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/dagdeel>
   a skos:Concept ;
   skos:prefLabel "dagdeel"@nl ;
   skos:altLabel "dagdeel (IntensiteitgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor> ;
   skos:definition '''Afgebakend tijdsvak binnen etmaal, waarvan het geheel van tijdsvakken samen een etmaal beslaat.'''@nl ;
   skos:scopeNote '''
                              Dagperiode (7.00-19.00 uur)
                              Avondperiode (19.00-23.00 uur)
                              Nachtperiode (23.00-7.00 uur)
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.snelheid (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/snelheid>
   a skos:Concept ;
   skos:prefLabel "snelheid"@nl ;
   skos:altLabel "snelheid (IntensiteitgegevensSpoor)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor> ;
   skos:definition '''De representatieve snelheid van materieel in kilometer per uur in gehele cijfers.'''@nl ;
   skos:scopeNote '''De minimaal gehanteerde snelheid in de rekenmodellen bedraagt 40 km per uur.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor.remindicatie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/remindicatie>
   a skos:Concept ;
