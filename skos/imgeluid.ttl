# Construct: IMGeluid::VlakbronIndustrie.negeerOverdrachtsobjecten (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/negeerOverdrachtsobjecten>
   a skos:Concept ;
   skos:prefLabel "negeerOverdrachtsobjecten"@nl ;
   skos:altLabel "negeerOverdrachtsobjecten (VlakbronIndustrie)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/VlakbronIndustrie> ;
   skos:definition '''Wanneer dit waar is, kan worden opgegeven dat eventuele gebouwen en schermen binnen de vlakbron niet worden gezien door de puntbronnen welke tot de vlakbron behoren.'''@nl ;
   skos:scopeNote '''Deze optie bestaat omdat het bronvermogen per m2 vaak gegeven is inclusief de bebouwing op de kavel.
Deze attribuutsoort wordt gebruikt om aan te geven dat de vlakbron een Oppervlaktebron is waarbinnen reflecterende en afschermende objecten worden genegeerd. Dit geldt dus niet voor andere items zoals procesinstallatiegebieden
Wanneer \"negeerOverdrachtsobjecten\" waar is, zijn alle Geluidoverdrachtobjecten met een geometrie die gedeeltelijk of helemaal overlapt met de geometrie van het Geluidbronvlak, niet meegenomen bij het berekenen van de overdracht van alle puntbronnen die in relatie staan met het desbetreffende Geluidbronvlak en ontvanger;'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelGPP (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/WegdeelGPP>
   a skos:Concept ;
   skos:prefLabel "WegdeelGPP"@nl ;
   dct:created "2019-06-17"^^xsd:date ;
   dct:modified "2022-05-02"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Kleinste functioneel onafhankelijk stukje van een NEN 3610 Weg met gelijkblijvende, homogene akoestische eigenschappen en relaties en primair bedoeld voor het representeren van akoestische eigenschappen van wegverkeer op rijkswegen of provinciale wegen.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelGPP.geluidbronregisterlijn (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geluidbronregisterlijn>
   a skos:Concept ;
   skos:prefLabel "geluidbronregisterlijn"@nl ;
   skos:altLabel "geluidbronregisterlijn (WegdeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/WegdeelGPP> ;
   skos:definition '''Een 3D-Lijn gelegen boven een wegdeel die fungeert als meetkundige representatie van de geluidbron.'''@nl ;
   skos:scopeNote '''Het bevoegd gezag bepaalt zelf de locatie en de hoeveelheid geluidbronregisterlijnen die het nodig acht voor de bepaling van het geluidproductieplafond en de monitoring daarvan. Het begin- en eindpunt van de lijn wordt bepaald door het punt in de ruimte waarop één van de akoestische eigenschappen van de geluidbron wijzigt.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelGPP.plafondcorrectie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/plafondcorrectie>
   a skos:Concept ;
   skos:prefLabel "plafondcorrectie"@nl ;
   skos:altLabel "plafondcorrectie (WegdeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/WegdeelGPP> ;
   skos:definition '''Getal (met één cijfer achter de komma) waarmee de geluidemissie van een daarbij in het geluidregister aangegeven gedeelte van een weg of spoorweg wordt vermeerderd voor het bepalen van de geluidproductie of de geluidbelasting. '''@nl ;
   skos:scopeNote '''Een \'0\' invoeren indien niet toegepast (de waarde \'0\' is bij GPP\'s over algemeen een prognose).'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelGPP.wegdektype (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/wegdektype>
   a skos:Concept ;
   skos:prefLabel "wegdektype"@nl ;
   skos:altLabel "wegdektype (WegdeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/WegdeelGPP> ;
   skos:definition '''Classificatie van typen toplagen op een wegdeel waarvan geluidreducerende effecten per type zijn vertaald naar correctiewaarden die gezamenlijk worden uitgedrukt met de bronterm Cwegdek.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelGPP.verkeersgegevens (attrib) (GEGEVENSGROEP)
<http://definities.geostandaarden.nl/img/id/concept/verkeersgegevens>
   a skos:Concept ;
   skos:prefLabel "verkeersgegevens"@nl ;
   skos:altLabel "verkeersgegevens (WegdeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/WegdeelGPP> ;
   skos:definition '''Verkeersgegevens met betrekking op een wegdeel, bestaande uit de gemiddelde intensiteit en snelheid voor iedere motorvoertuigklasse tijdens een dagdeel.
De intensiteit is gegeven als het aantal motorvoertuigen, per dagdeel, per motorvoertuigklasse, dat gemiddeld over een kalenderjaar per uur  passeert.
De gegeven snelheid is de representatief te achten snelheid in kilometer per uur zonder cijfers achter de komma van een klasse motorvoertuigen tijdens een dagdeel.'''@nl ;
   skos:scopeNote '''De etmaalperiode (ook wel: dagdeel) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.\nEtmaalperioden:\n
                              Dag (7.00-19.00 uur)
                              Avond (19.00-23.00 uur)
                              Nacht (23.00-7.00 uur)
                           \nDe motorvoertuigklassen bestaan uit:\n
                              Licht
                              Middelzwaar
                              Zwaar
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoordeelGPP (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP>
   a skos:Concept ;
   skos:prefLabel "SpoordeelGPP"@nl ;
   dct:created "2019-10-30"^^xsd:date ;
   dct:modified "2021-11-08"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Gedeelte van een spoorbaan met homogene akoestische eigenschappen.'''@nl ;
   skos:scopeNote '''
                        Een spoorbaan in het informatiemodel is opgebouwd uit allemaal afzonderlijke segmenten, de Spoordelen.
                        Een Spoordeel dient homogene eigenschappen te hebben.
                        Indien één van de eigenschappen van een Spoordeel verandert, bijvoorbeeld de snelheid, dan ontstaat er een nieuw Spoordeel.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoordeelGPP.geluidbronregisterlijn (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geluidbronregisterlijn>
   a skos:Concept ;
   skos:prefLabel "geluidbronregisterlijn"@nl ;
   skos:altLabel "geluidbronregisterlijn (SpoordeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP> ;
   skos:definition '''Meetkundige representatie van een deel van een spoorweg, gemodelleerd als een 3D-lijn, waarover de geluidemissie van spoorvoertuiggeluid min of meer constant kan worden verondersteld, gelet op de snelheden, intensiteiten, bovenbouwconstructie en de baangesteldheid. '''@nl ;
   skos:scopeNote '''Dit is over het algemeen de hartlijn van de spoorbaan. Dit wordt ook wel de bronregisterlijn genoemd.
De Z-waarde voor de hoogte van het spoor is de bovenkant van de spoorstaaf (BS). Zie ook fig 33 uit de meet en rekenvoorschriften: 
fig33_dwarsdoorsnee_talud)'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoordeelGPP.plafondcorrectie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/plafondcorrectie>
   a skos:Concept ;
   skos:prefLabel "plafondcorrectie"@nl ;
   skos:altLabel "plafondcorrectie (SpoordeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP> ;
   skos:definition '''Getal (met één cijfer achter de komma) waarmee de geluidemissie van een daarbij in het geluidregister aangegeven gedeelte van een weg of spoorweg wordt vermeerderd voor het bepalen van de geluidproductie of de geluidbelasting.'''@nl ;
   skos:scopeNote '''
                              De plafondcorrectiewaarde is de toeslag die wordt toegepast bij berekeningen op basis van de brongegevens uit het geluidregister.
                              De plafondcorrectiewaarde is dus van belang in rekenmodellen (voor berekeningen op referentiepunten of op woningniveau) die geheel of gedeeltelijk op registerdata zijn gebaseerd.
                           '''@nl ;
.

# Construct: IMGeluid::SpoordeelGPP.wissel (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/wissel>
   a skos:Concept ;
   skos:prefLabel "wissel"@nl ;
   skos:altLabel "wissel (SpoordeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP> ;
   skos:definition '''Een wissel is een installatie in een spoorweg om een trein, metro of tram naar een ander spoor te leiden'''@nl ;
   skos:scopeNote '''Spoordeel maakt deel uit van een wissel.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoordeelGPP.bovenbouw (attrib) (GEGEVENSGROEP)
<http://definities.geostandaarden.nl/img/id/concept/bovenbouw>
   a skos:Concept ;
   skos:prefLabel "bovenbouw"@nl ;
   skos:altLabel "bovenbouw (SpoordeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP> ;
   skos:definition '''De constructie die het dragen en geleiden van spoorvoertuigen verzorgd en gelegen is op de onderbouw (het geheel van aardenbaan en kunstwerken. Dit is de dragende constructie voor de bovenbouw).'''@nl ;
   skos:scopeNote '''Het geheel van spoorconstructie: (dikte van) ballastbed, dwarsligger, bevestiging, voegen en railruwheid. '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoordeelGPP.intensiteit (attrib) (GEGEVENSGROEP)
<http://definities.geostandaarden.nl/img/id/concept/intensiteit>
   a skos:Concept ;
   skos:prefLabel "intensiteit"@nl ;
   skos:altLabel "intensiteit (SpoordeelGPP)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/SpoordeelGPP> ;
   skos:definition '''Verzameling van gegevens over het gemiddeld aantal voertuigverplaatsingen per dagdeel, spoorvoertuigcategorie, profieltype, rijrichting, treintype, op het betreffende Spoordeel.'''@nl ;
   skos:scopeNote '''Dit is een repeterende gegevensgroep; een Spoordeel kan meerdere gegevensgroepen met intensiteitsgegevens bevatten.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelBGE (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/WegdeelBGE>
   a skos:Concept ;
   skos:prefLabel "WegdeelBGE"@nl ;
   dct:created "2019-11-19"^^xsd:date ;
   dct:modified "2022-05-02"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Kleinste functioneel onafhankelijk stukje van een NEN 3610 Weg waarover de geluidemissie van wegverkeer constant kan worden verondersteld, gelet op het type wegdek, gemiddelde snelheid en verkeersintensiteiten. '''@nl ;
   skos:scopeNote '''
                        Dit een op akoestische toepassingen toegespitste definitie van een BGT-wegdeel.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::WegdeelBGE.rijlijn (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/rijlijn>
   a skos:Concept ;
   skos:prefLabel "rijlijn"@nl ;
   skos:altLabel "rijlijn (WegdeelBGE)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/WegdeelBGE> ;
   skos:definition '''Als 2D-Lijn gemodelleerde meetkundige representatie van de geluidafstraling.'''@nl ;
   skos:scopeNote '''
                              Heeft 2D-geometrie conform het GM_Curve datatype.
                           \n
                              Het bevoegd gezag bepaalt zelf de locatie en de hoeveelheid rijlijnen die het nodig acht voor de bepaling van de basisgeluidemissie en de monitoring daarvan.
                              Het begin- en eindpunt van de lijn wordt bepaald door het punt in de ruimte waarop één van de akoestische eigenschappen van de geluidbron wijzigt.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

