# Construct: IMGeluid::Geluidproductieplafondobject (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Geluidproductieplafondobject>
   a skos:Concept ;
   skos:prefLabel "Geluidproductieplafondobject"@nl ;
   dct:created "2019-09-12"^^xsd:date ;
   dct:modified "2023-06-15"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/GemonitordObject> ;
   skos:definition '''Een punt in Nederland waar ter referentie is vastgesteld wat de maximale toegstane geluidbelasting per etmaalperiode mag zijn die geproduceerd wordt door een Rijksweg, een provinciale weg, een industrieterrein, of het hoofdspoor.'''@nl ;
   skos:scopeNote '''Het geluidproductieplafondobject is een verzamelobject dat de in een besluit vastgestelde  GPP-waarde op een referentiepunt opslaat, samen met informatie over een eventueel van toepassing zijnde ontheffing of een vrijstelling.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidproductieplafondobject.geometrieReferentiepunt (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrieReferentiepunt>
   a skos:Concept ;
   skos:prefLabel "geometrieReferentiepunt"@nl ;
   skos:altLabel "geometrieReferentiepunt (Geluidproductieplafondobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidproductieplafondobject> ;
   skos:definition '''De als een 3D punt gemodelleerde meetkundige representatie van de locatie, van een door het bevoegd gezag vastgesteld geluidproductieplafond, op vaste afstand t.o.v. van een rijksweg, een provinciale weg, een spoorbaan of een industrieterrein.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidproductieplafondobject.hoogteReferentiepunt (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/hoogteReferentiepunt>
   a skos:Concept ;
   skos:prefLabel "hoogteReferentiepunt"@nl ;
   skos:altLabel "hoogteReferentiepunt (Geluidproductieplafondobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidproductieplafondobject> ;
   skos:definition '''Hoogteverschil tussen de z-waarde uit de geometrie van referentiepunt en het plaatselijk maaiveld uitgedruk in meters met 1 cijfer achter de komma.'''@nl ;
   skos:scopeNote ''' Bij het bepalen van de hoogte van referentiepunten kan worden uitgegaan van een gemiddelde maaiveldhoogte rond een referentiepunt. Voor het bepalen van een gemiddelde maaiveldhoogte wordt het maximale gebied bepaald door een cirkel met straal 10 m rond het referentiepunt. Ten opzichte van dat gemiddelde mag de hoogte niet meer dan 10% af te wijken van 4,0 m hoogte.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidproductieplafondobject.geluidproductieplafond (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geluidproductieplafond>
   a skos:Concept ;
   skos:prefLabel "geluidproductieplafond"@nl ;
   skos:altLabel "geluidproductieplafond (Geluidproductieplafondobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidproductieplafondobject> ;
   skos:definition '''De door het bevoegd gezag vastgestelde maximaal toegestane jaargemiddelde geluidbelasting (Lden) in dB op een referentiepunt over de periode van een etmaal met één cijfer achter de komma.'''@nl ;
   skos:scopeNote '''
                              Lden staat voor Level day evening night.
                              Deze attribuutsoort is van toepassing op de domeinen: industrie, spoor en weg.
                              Sommige domeinen kennen aanvullende GPP-waarden. Deze worden als aparte attribuutsoort opgenomen binnen dit object.
                           '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidproductieplafondobject.tijdelijkeOntheffingswaarde (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/tijdelijkeOntheffingswaarde>
   a skos:Concept ;
   skos:prefLabel "tijdelijkeOntheffingswaarde"@nl ;
   skos:altLabel "tijdelijkeOntheffingswaarde (Geluidproductieplafondobject)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Geluidproductieplafondobject> ;
   skos:definition '''Aantal dB waarmee het geldende GPP verhoogd wordt gedurende de geldigheid van de tijdelijke ontheffing met 1 cijfer achter de komma.'''@nl ;
   skos:scopeNote '''Dit is geen verplicht gegeven. '''@nl ;
   dct:source "IMGeluid" ;
.

