# Construct: IMGeluid::Uitstralingsrichtingwaarde (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/Uitstralingsrichtingwaarde>
   a skos:Concept ;
   skos:prefLabel "Uitstralingsrichtingwaarde"@nl ;
   dct:created "2019-09-11"^^xsd:date ;
   dct:modified "2023-02-27"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Bepaalt de breedte en richting van geluidsemissie vanaf een \'normale puntbron\', \'uitstralende gevel\' of een \'uitstralend dak\'.'''@nl ;
   skos:scopeNote '''
                        Kan ook worden gemodelleerd door 2 punten in model te gebruiken. Een met kleinere emissie en 1 met grotere emissie.
                     \n
                        Wanneer geen uitstralingsrichting bekend is, wordt default 360 graden ingevuld bij de openingshoek van de UitstralingsrichtingWaarde en 0 graden bij de uitstralingsrichting.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Uitstralingsrichtingwaarde.openingshoek (attrib) (DATA ELEMENT)
<http://definities.geostandaarden.nl/img/id/concept/openingshoek>
   a skos:Concept ;
   skos:prefLabel "openingshoek"@nl ;
   skos:altLabel "openingshoek (Uitstralingsrichtingwaarde)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Uitstralingsrichtingwaarde> ;
   skos:definition '''Opening van de hoek van emissie-uitstraling met als midden de uitstralingsrichting in booggraden. '''@nl ;
   skos:scopeNote '''Wanneer openingshoek 360 graden, \'uitstralingsrichting\' == 0'''@nl ;
.

# Construct: IMGeluid::Uitstralingsrichtingwaarde.uitstralingsrichting (attrib) (DATA ELEMENT)
<http://definities.geostandaarden.nl/img/id/concept/uitstralingsrichting>
   a skos:Concept ;
   skos:prefLabel "uitstralingsrichting"@nl ;
   skos:altLabel "uitstralingsrichting (Uitstralingsrichtingwaarde)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/Uitstralingsrichtingwaarde> ;
   skos:definition '''Richting waar emissie naar uitstraalt in booggraden.'''@nl ;
   skos:scopeNote '''Uitgedrukt in graden volgens kompasrichtingen.'''@nl ;
.

