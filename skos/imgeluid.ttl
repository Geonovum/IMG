   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/GeluidgegevenscollectieElement> ;
.

# Construct: IMGeluid::Optrektoeslagvlak (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Optrektoeslagvlak>
   a skos:Concept ;
   skos:prefLabel "Optrektoeslagvlak"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Vlak waarbinnen een kruising of ander obstakel zich bevindt, dat dient voor de berekening van de bijbehorende optrektoeslagpunten. '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::GeluidgegevenscollectieElement (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/GeluidgegevenscollectieElement>
   a skos:Concept ;
   skos:prefLabel "GeluidgegevenscollectieElement"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Basiselement om aan te geven dat een object direct deel kan uitmaken van een Geluidgegevenscollectie via de relatie featureMember.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Optrektoeslagpunt (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Optrektoeslagpunt>
   a skos:Concept ;
   skos:prefLabel "Optrektoeslagpunt"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidemissieobject> ;
   skos:definition '''Punt waarvoor een toeslag wordt berekend ten gevolge van het optrekken omdat er een kruispunt of obstakel ligt.'''@nl ;
   skos:scopeNote '''Voorbeelden zijn: kruisingen, drempels of minirotondes.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Geluidcontour (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Geluidcontour>
   a skos:Concept ;
   skos:prefLabel "Geluidcontour"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Een lijn die punten met een gelijke geluidbelasting verbindt.'''@nl ;
   skos:scopeNote '''
                        Per 1 dB moet een contour worden berekend.
                        Bij luchtvaart is het bereik van 48 dB Lden tot 70 dB.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::SpoorstaafruwheidWaarde (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/SpoorstaafruwheidWaarde>
   a skos:Concept ;
   skos:prefLabel "SpoorstaafruwheidWaarde"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/GeluidgegevenscollectieElement> ;
   skos:definition '''Gemeten amplitude per golflengte van de oneffenheden in een spoorstaaf.'''@nl ;
   skos:scopeNote '''Golflengtes zijn in mm en worden aflopend ingevoerd.'''@nl ;
.

# Construct: IMGeluid::FlyoverZijkant (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant>
   a skos:Concept ;
   skos:prefLabel "FlyoverZijkant"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Zijkant van een fly-over.'''@nl ;
   skos:scopeNote '''De zijkant van een fly-over is een Geluidoverdrachtobject en lijkt akoestisch op een Geluidscherm. Sommige eigenschappen zijn echter anders en daarom is een aparte klasse opgenomen in het model.'''@nl ;
.

# Construct: IMGeluid::FactorPerOctaafband (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/FactorPerOctaafband>
   a skos:Concept ;
   skos:prefLabel "FactorPerOctaafband"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Fractiewaarde per octaafband.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::NEN3610ID (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/NEN3610ID>
   a skos:Concept ;
   skos:prefLabel "NEN3610ID"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''identificatiegegevens voor de universeel unieke identificatie van een object'''@nl ;
   skos:scopeNote '''De combinatie van namespace van een registratie, lokale identificatie en versie informatie maken een object uniek identificeerbaar. Met de informatie van deze klasse kan daardoor met zekerheid worden verwezen naar het geïdentificeerde object.'''@nl ;
   dct:source "NEN 3610:2011" ;
.

# Construct: IMGeluid::WaardePerOctaafband (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/WaardePerOctaafband>
   a skos:Concept ;
   skos:prefLabel "WaardePerOctaafband"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Gedeelte van het geluidspectrum waarbij de hoogste frequentie twee keer de laagste frequentie bezit.'''@nl ;
   skos:scopeNote '''In Nederland  wordt veelal gebruik gemaakt van de volgende octaafbanden met midden frequenties van: 31,5;63;125;250;500;1000;2000;4000 en 8000 Hz.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::KvKNummer (PRIMITIEF DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/KvKNummer>
   a skos:Concept ;
   skos:prefLabel "KvKNummer"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''String met het nummer dat door de Kamer van Koophandel is toegekend aan een organisatie om deze uniek te identificeren.'''@nl ;
.

# Construct: IMGeluid::Uitstralingsrichtingwaarde (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/Uitstralingsrichtingwaarde>
   a skos:Concept ;
   skos:prefLabel "Uitstralingsrichtingwaarde"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Bepaalt de breedte en richting van geluidsemissie vanaf een \'normale puntbron\', \'uitstralende gevel\' of een \'uitstralend dak\'.'''@nl ;
   skos:scopeNote '''
                        Kan ook worden gemodelleerd door 2 punten in model te gebruiken. Een met kleinere emissie en 1 met grotere emissie.
                     \n
                        Wanneer geen uitstralingsrichting bekend is, wordt default 360 graden ingevuld bij de openingshoek van de UitstralingsrichtingWaarde en 0 graden bij de uitstralingsrichting.
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::BedrijfsduurcorrectieWaarde (GESTRUCTUREERD DATATYPE)
<http://definities.geostandaarden.nl/img/id/concept/BedrijfsduurcorrectieWaarde>
   a skos:Concept ;
   skos:prefLabel "BedrijfsduurcorrectieWaarde"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Tijd in uren per dagdeel waar geluidbron actief is.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::HerkomstCollectie (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/HerkomstCollectie>
   a skos:Concept ;
   skos:prefLabel "HerkomstCollectie"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Identificatie van de leverancier en bronhouder van een \"Geluidgegevenscollectie\".'''@nl ;
.

# Construct: IMGeluid::Geluidtoeslag (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/Geluidtoeslag>
   a skos:Concept ;
   skos:prefLabel "Geluidtoeslag"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Verzameling van geluidtoeslaggegevens van treinvoertuigen per octaafband die zich over een brug verplaatsen.'''@nl ;
   skos:scopeNote '''
                        Een brugwand is een zwevend scherm waardoor ook geluidimmissies van onderliggende sporen goed berekend kunnen worden. Er moet in zo een geval nader onderzoek gedaan worden naar de geluiduitstraling van het kunstwerk.
                     '''@nl ;
.

# Construct: IMGeluid::BovenbouwgegevensSpoor (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/BovenbouwgegevensSpoor>
   a skos:Concept ;
   skos:prefLabel "BovenbouwgegevensSpoor"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''De constructie die het dragen en geleiden van spoorvoertuigen verzorgt en gelegen is op de onderbouw (het geheel van aardebaan en kunstwerken. Dit is de dragende constructie voor de bovenbouw).'''@nl ;
   skos:scopeNote '''Het geheel van spoorconstructie: (dikte van) ballastbed, dwarsligger, bevestiging, voegen en railruwheid. Er bestaan 2 bovenbouwconstructies, te weten:\n
                        De ballastconstructie; deze bestaat uit ballast, dwarsliggers, spoorstaven en wissels alsmede het bijbehorende bevestigingsmateriaal;
                        Ballastloze constructie; deze bestaat uit: een doorlopende plaat van beton, spoorstaven, bevestigingsmiddelen al dan niet gevat in een gietmassa. Komt o.a. voor bij tankinstallatie, wasinstallaties en kunstwerken
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::IntensiteitgegevensSpoor (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/IntensiteitgegevensSpoor>
   a skos:Concept ;
   skos:prefLabel "IntensiteitgegevensSpoor"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Verzameling van intensiteitgegevens van treinvoertuigen die zich per etmaalperiode over een Spoordeel verplaatsen.'''@nl ;
   skos:scopeNote '''
                        Geheel van informatie over de intensiteit waarmee treinvoertuigen zich over een spoortak verplaatsen, waarbij per dagdeel het snelheidsprofiel, de intensiteit, de rijrichting, de spoorvoertuigcategorie en het treintype worden vastgelegd.
                        Het dagdeel (ook wel: etmaalperiode) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.
                     \n
                        Etmaalperioden
                     \n
                        Dagperiode (7.00-19.00 uur)
                        Avondperiode (19.00-23.00 uur)
                        Nachtperiode (23.00-7.00 uur)
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::VerkeersgegevensWeg (GEGEVENSGROEPTYPE)
<http://definities.geostandaarden.nl/img/id/concept/VerkeersgegevensWeg>
   a skos:Concept ;
   skos:prefLabel "VerkeersgegevensWeg"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Verkeersgegevens met betrekking op een wegdeel, bestaande uit de gemiddelde intensiteit en snelheid voor iedere motorvoertuigklasse tijdens een dagdeel.
De intensiteit is gegeven als het aantal motorvoertuigen, per dagdeel, per motorvoertuigklasse, dat gemiddeld over een kalenderjaar per uur  passeert.
De gegeven snelheid is de representatief te achten snelheid in kilometer per uur zonder cijfers achter de komma van een klasse motorvoertuigen tijdens een dagdeel.'''@nl ;
   skos:scopeNote '''De etmaalperiode (ook wel: dagdeel) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.\nEtmaalperioden:\n
                        Dag (7.00-19.00 uur)
                        Avond (19.00-23.00 uur)
                        Nacht (23.00-7.00 uur)
                     \nDe motorvoertuigklassen bestaan uit:\n
                        Licht
                        Middelzwaar
                        Zwaar
                     '''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::Schermtype (ENUMERATIE)
<http://definities.geostandaarden.nl/img/id/collection/Schermtype>
   a skos:Collection ;
   skos:prefLabel "Schermtype"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''De gehanteerde categorisering van de type geluidschermen.'''@nl ;
   skos:scopeNote '''De schermwerking is voor ieder type hetzelfde, maar het is voor adviesbureaus en andere partijen waardevol om de herkomst van het scherm op basis van de typering te kunnen herleiden.'''@nl ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/brugwand> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/geluidscherm> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/geluidwal> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/overkappingszijwand> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/perronrand> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/tunnelbakwand> ;
.

# Construct: IMGeluid::Schermtype.brugwand (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/brugwand>
   a skos:Concept ;
   skos:prefLabel "brugwand"@nl ;
   skos:altLabel "brugwand (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Een geluidscherm op een brug of verticaal oppervlak aan 1 of 2 zijden van een brug dat als geluidscherm fungeert.'''@nl ;
   skos:scopeNote '''Bij een brugwand is de reflectiefactor wel relevant voor de GPP-berekening'''@nl ;
.

# Construct: IMGeluid::Schermtype.geluidscherm (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/geluidscherm>
   a skos:Concept ;
   skos:prefLabel "geluidscherm"@nl ;
   skos:altLabel "geluidscherm (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Ter verbetering van de kwaliteit van het milieu direct langs een geluidbron geplaatst geluidregisterscherm dat gebruikt is in de GPP-berekening.'''@nl ;
.

# Construct: IMGeluid::Schermtype.geluidwal (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/geluidwal>
   a skos:Concept ;
   skos:prefLabel "geluidwal"@nl ;
   skos:altLabel "geluidwal (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Ter verbetering van de kwaliteit van het milieu direct langs een geluidbron geplaatste geluidwal dat gebruikt is in de GPP-berekening.'''@nl ;
.

# Construct: IMGeluid::Schermtype.overkappingszijwand (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/overkappingszijwand>
   a skos:Concept ;
   skos:prefLabel "overkappingszijwand"@nl ;
   skos:altLabel "overkappingszijwand (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Een geluidscherm onder een overkapping of verticaal oppervlak aan 1 of 2 zijden van een overkapping dat als geluidscherm fungeert.'''@nl ;
   skos:scopeNote '''Een overkappingszijwand heeft een reflectiefactor die relevant is voor (wordt meegenomen in) de GPP-berekening'''@nl ;
.

# Construct: IMGeluid::Schermtype.perronrand (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/perronrand>
   a skos:Concept ;
   skos:prefLabel "perronrand"@nl ;
   skos:altLabel "perronrand (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''De verticale wand langs het spoor die de hoogte overbrugt tussen de bovenkant van het spoor en de bovenkant van het perron.'''@nl ;
   skos:scopeNote '''
                              Tussen een passerende trein en de perronrand kan het geluid heen-en-weer kaatsen. Verder heeft een perronrand heeft in principe een default-hoogte van 80cm, maar er zijn uitzonderingen in het register die deze hoogte ruimschoots overschrijden.
                              Een perron heeft geen reflectiefactor want het heeft juridisch een andere oorsprong dan bijvoorbeeld een brugwand. Een perron heeft namelijk niet als hoofddoel \'geluidafscherming\'.
                           '''@nl ;
.

# Construct: IMGeluid::Schermtype.tunnelbakwand (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/tunnelbakwand>
   a skos:Concept ;
   skos:prefLabel "tunnelbakwand"@nl ;
   skos:altLabel "tunnelbakwand (Schermtype)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Een verticaal oppervlak aan de zijde van een tunnelbak dat als geluidscherm fungeert.'''@nl ;
   skos:scopeNote '''Vraag: heeft een tunnelbakrand een reflectiefactor die relevant is voor (wordt meegenomen in) de GPP-berekening?'''@nl ;
.

# Construct: IMGeluid::Hoogtelijntype (ENUMERATIE)
<http://definities.geostandaarden.nl/img/id/collection/Hoogtelijntype>
   a skos:Collection ;
   skos:prefLabel "Hoogtelijntype"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Classificatie van het soort hoogtelijn.'''@nl ;
   skos:scopeNote '''
                        ProRail heeft het hoogtelijnenmodel vereenvoudigd en onderscheid nu vijf verschillende typen hoogtelijnen. 
                        De typen Tunnelbaklijn, balastbedlijn en kantaardebaanlijn komen uit het spoorregister en mogen niet aangepast worden. 
                        De andere twee typen komen uit het Actueel Hoogtebestand Nederland (AHN). Deze typen, de teentaludlijn en de referentiepuntenlijn, mag een adviesbureau aanpassen.
                     '''@nl ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/ballastbedlijn> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/kantaardebaanlijn> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/teentaludlijn> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/referentiepuntenlijn> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/tunnelbaklijn> ;
.

