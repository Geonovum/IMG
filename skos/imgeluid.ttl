.

# Construct: IMGeluid::ProfieltypeGeluidscherm (ENUMERATIE)
<http://definities.geostandaarden.nl/img/id/collection/ProfieltypeGeluidscherm>
   a skos:Collection ;
   skos:prefLabel "ProfieltypeGeluidscherm"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Vormaanduiding van het type geluidscherm'''@nl ;
   skos:scopeNote '''Deze klassen corresponderen met vaste profielcorrectiewaarden van 0,0 dB, 2,0 dB of 5,0 dB.'''@nl ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/scherp> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/stomp> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/perron> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/middenberm> ;
   skos:member <http://definities.geostandaarden.nl/img/id/concept/t-top> ;
.

# Construct: IMGeluid::ProfieltypeGeluidscherm.scherp (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/scherp>
   a skos:Concept ;
   skos:prefLabel "scherp"@nl ;
   skos:altLabel "scherp (ProfieltypeGeluidscherm)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Alle gebouwen, dunne wanden waarvan de hoek met verticaal = 20°, grondlichamen met 0° = T = 70°, alle grondlichamen met daarop een dunne wand, als de totale constructiehoogte minder dan twee maal de hoogte van die wand is, of als de wand hoger is dan 3,5 m, bij toepassing van een schermtop en waarvan het effect met de correctieterm CT in rekening wordt gebracht.'''@nl ;
   skos:scopeNote '''De profielcorrectie van een scherp scherm is 0,0 dB'''@nl ;
.

# Construct: IMGeluid::ProfieltypeGeluidscherm.stomp (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/stomp>
   a skos:Concept ;
   skos:prefLabel "stomp"@nl ;
   skos:altLabel "stomp (ProfieltypeGeluidscherm)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Alle randen van weglichamen in ophoging, randen van wegen op een viaduct, alle grondlichamen met daarop een dunne wand, als de totale constructiehoogte meer bedraagt dan twee maal de hoogte van die wand en de wand niet hoger is dan 3,5 m en grondlichamen met 70° < T = 165°'''@nl ;
   skos:scopeNote '''De profielcorrectiewaarde van een stomp scherm is 2,0 dB'''@nl ;
.

# Construct: IMGeluid::ProfieltypeGeluidscherm.perron (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/perron>
   a skos:Concept ;
   skos:prefLabel "perron"@nl ;
   skos:altLabel "perron (ProfieltypeGeluidscherm)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Rand van het perron.'''@nl ;
   skos:scopeNote '''De perronrand heeft een afschermende werking en wordt gemodelleerd als een scherm van 0,8 meter hoogte, gemeten vanaf de bovenkant van het spoor. De profielcorrectie van een perron is 5,0 dB.'''@nl ;
.

# Construct: IMGeluid::ProfieltypeGeluidscherm.middenberm (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/middenberm>
   a skos:Concept ;
   skos:prefLabel "middenberm"@nl ;
   skos:altLabel "middenberm (ProfieltypeGeluidscherm)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Afschermende object dat bestaat uit dunne wanden en waarvoor geldt dat in het betreffende pad tussen bron- en waarneempunt zich behalve het genoemde afschermende object een tweede afschermend object bevindt op een afstand van, loodrecht gemeten, ten hoogste 50 meter en waarvan de hoogte ten minste gelijk is aan de bronhoogte. Daarnaast bevindt zich tussen beide afschermende objecten ten minste één rijlijn. Als niet aan deze voorwaarden voldaan is, dan wordt de afschermende werking van het middenbermscherm op eenzelfde manier bepaald als van andere afschermende objecten.'''@nl ;
   skos:scopeNote '''Een middenbememscherm heeft geen profielcorrectie: correctie = 0).'''@nl ;
.

# Construct: IMGeluid::ProfieltypeGeluidscherm.t-top (attrib) (ENUMERATIEWAARDE)
<http://definities.geostandaarden.nl/img/id/concept/t-top>
   a skos:Concept ;
   skos:prefLabel "t-top"@nl ;
   skos:altLabel "t-top (ProfieltypeGeluidscherm)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Horizontaal geplaatst element boven op een scherm wat tot aanvullende schermwerking leidt.'''@nl ;
   skos:scopeNote '''Een t-top heeft geen profielcorrectie, maar gegeven de constrcutie hoort het bij een scherm met correctie 0'''@nl ;
.

