# Construct: IMGeluid::FlyoverZijkant (OBJECTTYPE)
<http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant>
   a skos:Concept ;
   skos:prefLabel "FlyoverZijkant"@nl ;
   dct:created "2022-07-08"^^xsd:date ;
   dct:modified "2022-07-11"^^xsd:date ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:broader <http://definities.geostandaarden.nl/img/id/concept/Geluidoverdrachtobject> ;
   skos:definition '''Zijkant van een fly-over.'''@nl ;
   skos:scopeNote '''De zijkant van een fly-over is een Geluidoverdrachtobject en lijkt akoestisch op een Geluidscherm. Sommige eigenschappen zijn echter anders en daarom is een aparte klasse opgenomen in het model.'''@nl ;
.

# Construct: IMGeluid::FlyoverZijkant.geometrie (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/geometrie>
   a skos:Concept ;
   skos:prefLabel "geometrie"@nl ;
   skos:altLabel "geometrie (FlyoverZijkant)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant> ;
   skos:definition '''Als 3d-lijn gemodelleerde meetkundige representatie van de onderkant van een Flyoverzijkant.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::FlyoverZijkant.reflectiefactorLinks (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/reflectiefactorLinks>
   a skos:Concept ;
   skos:prefLabel "reflectiefactorLinks"@nl ;
   skos:altLabel "reflectiefactorLinks (FlyoverZijkant)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant> ;
   skos:definition '''De reflectiefactor van de door de linkerzijde van de FlyoverZijkant gereflecteerde geluidsenergie per octaafband.'''@nl ;
   skos:scopeNote '''Wanneer er gesproken wordt over links en rechts, dan is dit relatief aan de digitaliseringsrichting van de lijn. Om te bepalen wat de linker en rechter kant is, kan je met de digitaliseringsrichting mee over de lijn lopen. Aan je linkerhand bevindt zich dan de linkerzijde van de fly-over.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::FlyoverZijkant.reflectiefactorRechts (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/reflectiefactorRechts>
   a skos:Concept ;
   skos:prefLabel "reflectiefactorRechts"@nl ;
   skos:altLabel "reflectiefactorRechts (FlyoverZijkant)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant> ;
   skos:definition '''De reflectiefactor van de door de rechterzijde van de FlyoverZijkant gereflecteerde geluidsenergie per octaafband.'''@nl ;
   skos:scopeNote '''Wanneer er gesproken wordt over links en rechts, dan is dit relatief aan de digitaliseringsrichting van de lijn. Om te bepalen wat de linker en rechter kant is, kan je met de digitaliseringsrichting mee over de lijn te lopen. Aan je rechterhand bevindt zich dan de rechterzijde van de fly-over.'''@nl ;
   dct:source "IMGeluid" ;
.

# Construct: IMGeluid::FlyoverZijkant.hoogte (attrib) (ATTRIBUUTSOORT)
<http://definities.geostandaarden.nl/img/id/concept/hoogte>
   a skos:Concept ;
   skos:prefLabel "hoogte"@nl ;
   skos:altLabel "hoogte (FlyoverZijkant)"@nl ;
   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skosthes:broaderPartitive <http://definities.geostandaarden.nl/img/id/concept/FlyoverZijkant> ;
   skos:definition '''De hoogte van het reflecterende oppervlakte aan de zijkant van de fly-over in meters afgerond op 1 decimaal.'''@nl ;
   dct:source "IMGeluid" ;
.

