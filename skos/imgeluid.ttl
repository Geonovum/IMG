   skos:inScheme <http://definities.geostandaarden.nl/img/id/conceptscheme/IMGeluid> ;
   skos:definition '''Treinverkeer dat zich (met lage snelheid) verplaats op een spooremplacement'''@nl ;
   skos:scopeNote '''Bijvoorbeeld een rangerende treinstel'''@nl ;
.

# Construct: IMGeluid::Documenttype (ENUMERATIE)
<http://definities.geostandaarden.nl/img/id/collection/Documenttype>
   a skos:Collection ;
