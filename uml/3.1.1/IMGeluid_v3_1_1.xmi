															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Rand van het perron.&#xA;&#xA;--Regels--&#xA;Kan alleen van toepassing zijn indien &lt;b&gt;Geluidgegevenscollectie.geluidbron = hoofdspoor&lt;/b&gt;&#xA;&#xA;--Toelichting--&#xA;De perronrand heeft een afschermende werking en wordt gemodelleerd als een scherm van 0,8 meter hoogte, gemeten vanaf de bovenkant van het spoor. De profielcorrectie van een perron is 5,0 dB."/>
																<UML:TaggedValue tag="derived" value="0"/>
