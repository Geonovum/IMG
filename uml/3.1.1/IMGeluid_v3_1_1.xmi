																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Geeft aan of een Bouwwerk cilindervormig is.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Wanneer een gebouw een cilinder is worden andere absorptiewaardes toegekend.&lt;/li&gt;&#xA;	&lt;li&gt;Hoe met cilindrisch gaat worden omgegeaan is nog niet zeker. Wel is duidelijk geworden dat niet elk rekenpakket hier hetzelfde mee omgaat.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;"/>
																<UML:TaggedValue tag="type" value="Boolean"/>
																<UML:TaggedValue tag="derived" value="0"/>
