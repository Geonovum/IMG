														<UML:AssociationEnd visibility="public" multiplicity="1" name="industrieterrein" aggregation="none" isOrdered="false" targetScope="instance" changeable="none" isNavigable="true" type="EAID_1D01430D_AF7F_448d_B10E_DB334CFB14E9">
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="-- Definitie --&#xA;Industrieterrein waarvoor et Geluidproductieplafond is vastgesteld"/>
																<UML:TaggedValue tag="containment" value="Unspecified"/>
																<UML:TaggedValue tag="destStereotype" value="Relatierol"/>
																<UML:TaggedValue tag="deststyle" value="Union=0;Derived=0;AllowDuplicates=0;Owned=0;Navigable=Navigable;"/>
																<UML:TaggedValue tag="ea_end" value="target"/>
