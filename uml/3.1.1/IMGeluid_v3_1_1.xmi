												<UML:Class name="Gegevenscollectietype" xmi.id="EAID_B6773E1F_22D6_4682_B531_6A2D392A2B3C" visibility="public" namespace="EAPK_B7826611_7A52_4287_882C_1EE50369B927" isRoot="false" isLeaf="false" isAbstract="false">
