																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={AB4B5700-2E5B-4f24-9629-C95818B5DFCF}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Attribuutsoort;FQName=MIM::Attribuutsoort;@ENDSTEREO;$DES;$CLT={1555894E-9C06-4270-B4D5-54C4D2725424}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
