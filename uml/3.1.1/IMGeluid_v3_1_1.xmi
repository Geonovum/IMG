		<UML:TaggedValue tag="Toelichting" xmi.id="EAID_50A2721A_D0BE_44d0_B300_D385628AFC51" value="&lt;memo&gt;#NOTES#Voorbeelden zijn: huis, schuur, flatgebouw, huizenblok, fabriek." modelElement="EAID_A3F7184D_50E3_4d4d_B6B2_BB3127C7FBFC"/>
