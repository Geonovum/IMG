																<UML:Classifier xmi.idref="EAID_CCDDE1A3_5915_41e8_986C_F9F9271380A7"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Als 3D-vlak gemodelleerde meetkundige horizontaal platte representatie van het dak van een bouwwerk.&#xA;&#xA;--Regels--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Alle z-co&amp;#246;rdinaten in Bouwwerk.geometrie moeten hetzelfde zijn.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;De z-co&amp;#246;rdinaat representeert een hoogte die akoestische representatief is voor dat Bouwwerk.&lt;/li&gt;&#xA;	&lt;li&gt;Bij het modelleren van een complex bouwwerk mogen meerdere Bouwwerk objecten worden gebruikt.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="GM_Surface"/>
																<UML:TaggedValue tag="derived" value="0"/>
