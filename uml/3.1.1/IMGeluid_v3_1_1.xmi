														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={CA25DB84-970F-49d2-A729-AC30C36144A2}$XID;$NAM=Stereotypes$NAM;$TYP=connector property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Generalisatie;FQName=MIM::Generalisatie;@ENDSTEREO;$DES;$CLT={D2BF1D8E-950C-40db-B2DC-E08CA9293F41}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
