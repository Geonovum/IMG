														<UML:Stereotype name="enumeration"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Classificatie van het soort hoogtelijn.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;ProRail heeft het hoogtelijnenmodel vereenvoudigd en onderscheid nu vijf verschillende typen hoogtelijnen. &lt;/li&gt;&#xA;	&lt;li&gt;De typen Tunnelbaklijn, balastbedlijn en kantaardebaanlijn komen uit het spoorregister en mogen niet aangepast worden. &lt;/li&gt;&#xA;	&lt;li&gt;De andere twee typen komen uit het Actueel Hoogtebestand Nederland (AHN). Deze typen, de teentaludlijn en de referentiepuntenlijn, mag een adviesbureau aanpassen.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
