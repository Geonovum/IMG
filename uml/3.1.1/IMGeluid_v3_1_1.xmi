														<UML:TaggedValue tag="Datum opname" xmi.id="EAID_FB3F1EDB_45C3_1445_B750_BF459CA97AA1">
															<XMI.extension xmi.extender="Enterprise Architect 2.5">
																<UML:Comment name="Description: De datum waarop het informatie-element is opgenomen in het informatiemodel.&#xA;"/>
