		<UML:TaggedValue tag="Toelichting" xmi.id="EAID_50A2721A_D0BE_44d0_B18B_E3BFC81CA744" value="&lt;memo&gt;#NOTES#Bij het registreren van een object als informatieobject horen een aantal metadata die hier betrekking op hebben, zoals versie en registratie van tijdlijngegevens." modelElement="EAID_47CE152F_6789_46dc_A29F_33647F0A644A"/>
