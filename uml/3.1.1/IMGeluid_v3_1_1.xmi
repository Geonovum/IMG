		<UML:TaggedValue tag="Datum opname" xmi.id="EAID_FB3F1EDB_02AB_9502_A2B2_3B0DA3415F87" value="#NOTES#Description: De datum waarop het modelelement is opgenomen in het informatiemodel.&#xA;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
		<UML:TaggedValue tag="Formeel patroon" xmi.id="EAID_69EB40AD_527D_0c52_AA15_9760CB412834" value="#NOTES#Description: Zoals patroon, formeel vastgelegd, uitgedrukt in een formele taal die door de computer wordt herkend.&#xA;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_01FD_1001_AE14_7300E1D6CA30" value="#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xA;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
		<UML:TaggedValue tag="Herkomst definitie" xmi.id="EAID_1FAA1D3E_9D0E_ef9d_A1F8_1FA877089EE2" value="#NOTES#Description: De registratie of het informatiemodel waaruit de definitie is overgenomen dan wel een aanduiding die aangeeft uit welke bronnen de definitie is samengesteld.&#xA;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
		<UML:TaggedValue tag="Lengte" xmi.id="EAID_034EE5FF_2DCF_3a2d_9497_F2E2FF0B1FBC" value="#NOTES#Description: De aanduiding van de lengte van een gegeven, volgens de aangegeven notatiewijze.&#xA;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
		<UML:TaggedValue tag="Patroon" xmi.id="EAID_98327E03_BFD3_86bf_8534_00D754C4950B" value="&lt;memo&gt;" modelElement="EAID_E2B9D65E_26F0_4a1c_99EB_3D699CF3691C"/>
