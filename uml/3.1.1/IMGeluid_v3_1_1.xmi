		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_C751_5dc7_9211_CF9D41F365C2" value="nen 3610#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xA;" modelElement="EAID_85C106F3_B76B_4f9e_ACCF_AABCA792A479"/>
