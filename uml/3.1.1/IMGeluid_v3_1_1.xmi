													<UML:Classifier.feature>
														<UML:Attribute name="besluit" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
