															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;3D-geometrie die evenveel punten bevat als het attribuut 'geometrie' met dezelde x- en y- co&amp;#246;rdinaten. De z-co&amp;#246;rdinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Bouwwerk op het maaiveld.  &#xA;-- Regels--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Als maaiveld gevuld is moet deze evenveel punten bevatten als de geometrie met dezelfde x- en y-co&amp;#246;rdinaten in dezelfde volgorde.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="GM_Surface"/>
																<UML:TaggedValue tag="derived" value="0"/>
