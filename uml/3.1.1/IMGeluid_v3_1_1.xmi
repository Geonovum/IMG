															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;De door het bevoegd gezag vastgestelde maximaal toegestane jaargemiddelde geluidbelasting (Lden) in dB op een referentiepunt over de periode van een etmaal met &amp;#233;&amp;#233;n cijfer achter de komma.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Lden staat voor Level day evening night.&lt;/li&gt;&#xA;	&lt;li&gt;Deze attribuutsoort is van toepassing op de domeinen: industrie, spoor en weg.&lt;/li&gt;&#xA;	&lt;li&gt;Sommige domeinen kennen aanvullende GPP-waarden. Deze worden als aparte attribuutsoort opgenomen binnen dit object.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="Decimal"/>
																<UML:TaggedValue tag="derived" value="0"/>
