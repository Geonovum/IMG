												<UML:Class name="Schermtype" xmi.id="EAID_C9ACE184_6E2B_40c1_ACE0_A7C5EE554EF9" visibility="public" namespace="EAPK_B7826611_7A52_4287_882C_1EE50369B927" isRoot="false" isLeaf="false" isAbstract="false">
