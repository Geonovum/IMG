														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={90EB4B2B-20A7-4358-9173-830129465E27}$XID;$NAM=Stereotypes$NAM;$TYP=connector property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Generalisatie;FQName=MIM::Generalisatie;@ENDSTEREO;$DES;$CLT={282CA9D5-5649-4576-9C86-A49DC7FD7F10}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
