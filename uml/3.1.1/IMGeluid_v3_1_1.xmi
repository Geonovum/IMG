															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Begindatum van de situatie waarin wel een geluidproductieplafond is vastgesteld, maar waarop voor de duur van een bepaalde periode niet gemonitord hoeft te worden aan het geluidproductieplafond.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Een vrijstelling geldt in situaties waarin een trace- of project-besluit is genomen voor een nieuw aan te leggen (spoor-)weg waarvoor al wel een GPP is vastgesteld, maar er nog niets te monitoren valt, omdat er nog geen verkeersbewegingen kunnen zijn.&lt;/li&gt;&#xA;	&lt;li&gt;Een dergelijke situatie kan op &amp;#233;&amp;#233;n zelfde plek niet nogmaals voorkomen.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Zoals blijkt uit de kardinaliteit, kan er maar &amp;#233;&amp;#233;n vrijstelling(periode) voorkomen.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="Date"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
