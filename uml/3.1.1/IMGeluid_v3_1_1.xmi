		<UML:TaggedValue tag="Populatie" xmi.id="EAID_2D3C6693_CC37_aecc_90A3_0DED8EF1F5BF" value="&lt;memo&gt;" modelElement="EAID_99749D9E_9B0F_4134_959D_4D7BE81D0CEA"/>
		<UML:TaggedValue tag="Toelichting" xmi.id="EAID_50A2721A_D0BE_44d0_A07E_634065841EA1" value="&lt;memo&gt;#NOTES#Wegverkeerruimten worden gebruikt door bijvoorbeeld voetgangers, fietsers en autoverkeer." modelElement="EAID_99749D9E_9B0F_4134_959D_4D7BE81D0CEA"/>
		<UML:TaggedValue tag="Begrip" xmi.id="EAID_EBF7A679_4E9D_974e_A3CF_6FF5A486010D" value="http://definities.geostandaarden.nl/nen3610-2022/id/begrip/gebouw#NOTES#Description: Verwijzing naar een begrip, vanuit een modelelement, waarmee wordt aangegeven op welk begrip, of begrippen, het informatiemodel element is gebaseerd. De verwijzing heeft de vorm van een term of een URI.&#xA;" modelElement="EAID_A3F7184D_50E3_4d4d_B6B2_BB3127C7FBFC"/>
