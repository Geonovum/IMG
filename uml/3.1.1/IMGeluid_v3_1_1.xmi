																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={66F34D24-DFB8-40f8-8918-AC9C8EF31F0F}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Attribuutsoort;FQName=MIM::Attribuutsoort;@ENDSTEREO;$DES;$CLT={ED37853F-CD7E-4fa6-9462-6D03296F0911}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
