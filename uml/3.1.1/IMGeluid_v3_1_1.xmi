																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={8D5E7E20-E09A-4cbb-AC7E-80DE0F162E7D}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Enum;GUID={667D7D96-140A-49b4-B2A5-AFE88199DC42};FQName=NEN3610-BRO Grouping (EN)::Enum;@ENDSTEREO;$DES;$CLT={1E2CFB02-9F9F-4a2d-9237-B8F2F758BDA0}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
