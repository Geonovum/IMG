												<UML:Class name="WaardePerOctaafband" xmi.id="EAID_7AE14E60_44F9_4af5_A8D1_D005D44A25BE" visibility="public" namespace="EAPK_729A55D9_DFD4_4a0e_9A96_B6943B0636C7" isRoot="false" isLeaf="false" isAbstract="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Gestructureerd datatype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Gedeelte van het geluidspectrum waarbij de hoogste frequentie twee keer de laagste frequentie bezit.&#xA;&#xA;--Regels--&#xA;Band31Hz hoeft alleen te worden meegenomen wanneer emissie object uit domein Industrie afkomstig is.&#xA;&#xA;--Toelichting--&#xA;In Nederland  wordt veelal gebruik gemaakt van de volgende octaafbanden met midden frequenties van: 31,5;63;125;250;500;1000;2000;4000 en 8000 Hz."/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
