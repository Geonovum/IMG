													</UML:Classifier.feature>
												</UML:Class>
												<UML:Class name="VerkeersgegevensWeg" xmi.id="EAID_A5AB50E8_5A98_4426_A89E_F5C9D91CF6F8" visibility="public" namespace="EAPK_9FFE19D6_D894_4385_90E3_5924B33BBA1E" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Gegevensgroeptype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Verkeersgegevens met betrekking op een wegdeel, bestaande uit de gemiddelde intensiteit en snelheid voor iedere motorvoertuigklasse tijdens een dagdeel.&#xA;De intensiteit is gegeven als het aantal motorvoertuigen, per dagdeel, per motorvoertuigklasse, dat gemiddeld over een kalenderjaar per uur  passeert.&#xA;De gegeven snelheid is de representatief te achten snelheid in kilometer per uur zonder cijfers achter de komma van een klasse motorvoertuigen tijdens een dagdeel.&#xA;&#xA;--Toelichting--&#xA;De etmaalperiode (ook wel: dagdeel) is het gedeelte van een etmaal waarover het equivalent geluidsniveau wordt bepaald.&#xA;&#xA;Etmaalperioden:&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Dag (7.00-19.00 uur)&lt;/li&gt;&#xA;	&lt;li&gt;Avond (19.00-23.00 uur)&lt;/li&gt;&#xA;	&lt;li&gt;Nacht (23.00-7.00 uur)&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;De motorvoertuigklassen bestaan uit:&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Licht&lt;/li&gt;&#xA;	&lt;li&gt;Middelzwaar&lt;/li&gt;&#xA;	&lt;li&gt;Zwaar&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
														<UML:TaggedValue tag="package" value="EAPK_9FFE19D6_D894_4385_90E3_5924B33BBA1E"/>
														<UML:TaggedValue tag="date_created" value="2019-10-28 13:34:32"/>
														<UML:TaggedValue tag="date_modified" value="2022-05-02 14:37:00"/>
														<UML:TaggedValue tag="gentype" value="Java"/>
														<UML:TaggedValue tag="tagged" value="0"/>
														<UML:TaggedValue tag="package_name" value="AlgGegevensgroep"/>
														<UML:TaggedValue tag="phase" value="1.0"/>
														<UML:TaggedValue tag="author" value="g.trouborst"/>
														<UML:TaggedValue tag="complexity" value="1"/>
