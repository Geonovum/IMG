																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={B7F44532-0D8C-40a4-9185-2B64F28F1A67}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Attribuutsoort;FQName=MIM::Attribuutsoort;@ENDSTEREO;$DES;$CLT={F09FA2B7-41B6-4187-9162-F5D65615E331}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
