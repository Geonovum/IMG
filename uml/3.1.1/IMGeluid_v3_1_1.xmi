																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={9D58D8C3-F612-488c-A780-EFE62E323CA8}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Enum;GUID={667D7D96-140A-49b4-B2A5-AFE88199DC42};FQName=NEN3610-BRO Grouping (EN)::Enum;@ENDSTEREO;$DES;$CLT={3238A170-2078-400f-938C-0CB079E52408}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
