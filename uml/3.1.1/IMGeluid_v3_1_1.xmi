														</UML:Attribute>
														<UML:Attribute name="reflectiefactor" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_2E128FCF_DE66_4517_86D2_331E9E0C46EE"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;De fractie van de door het geveloppervlak gereflecteerde geluidenergie per octaafband.&#xA;&#xA;--Toelichting--&#xA;De reflectiefactor wordt per octaafband ingevoerd.&#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;reflectiefactor 1	: akoestisch reflecterende wand&lt;/li&gt;&#xA;	&lt;li&gt;reflectiefactor 0	: volledig absorberende wand&lt;/li&gt;&#xA;	&lt;li&gt;reflectiefactor 0.2	: voorkeurswaarde voor taluds, dijklichamen e.a.&lt;/li&gt;&#xA;	&lt;li&gt;reflectiefactor 0.8	: voorkeurswaarde voor overige gebouwen.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;De reflectiefactor wordt per octaafband ingevoerd en staat standaard op 0.8, dit komt overeen met 1 dB(A) geluidsniveauvermindering conform de reken- en meetvoorschriften.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="FactorPerOctaafband"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
																<UML:TaggedValue tag="precision" value="0"/>
																<UML:TaggedValue tag="scale" value="0"/>
																<UML:TaggedValue tag="static" value="0"/>
