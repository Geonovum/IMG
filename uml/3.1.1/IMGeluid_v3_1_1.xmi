													<UML:Association.connection>
														<UML:AssociationEnd visibility="public" multiplicity="1..*" aggregation="none" isOrdered="false" targetScope="instance" changeable="none" isNavigable="false" type="EAID_9AD15457_4880_42e5_8C72_4E5EFAC91B15">
