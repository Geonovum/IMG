												<UML:Class name="GeluidgegevenscollectieElement" xmi.id="EAID_924BD078_D715_461a_B7E9_D7176A7406E0" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="true" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="-- Definitie --&#xA;Basiselement om aan te geven dat een object direct deel kan uitmaken van een Geluidgegevenscollectie via de relatie featureMember.&#xA;"/>
