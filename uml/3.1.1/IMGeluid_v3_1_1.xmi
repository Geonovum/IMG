		<UML:TaggedValue tag="Alternatieve naam" xmi.id="EAID_4BF34B01_9D4E_1d9d_AB17_BCD041A8239C" value="#NOTES#Description: De naam in natuurlijke of formele taal; afhankelijk van gekozen aanpak. Een alternatieve naam.&#xA;" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Definitie" xmi.id="EAID_5F3916B1_6BFE_706b_98CB_EE56C9FD222E" value="#NOTES#Description: De beschrijving van de betekenis van de construct zoals gespecificeerd in de catalogus van de desbetreffende (basis)registratie of informatiemodel.&#xA;" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Is afgeleid" xmi.id="EAID_3B9D7FED_5C7A_ff5c_9D98_CDF8887E5446" value="Zie package#NOTES#Values: Nee,Ja,Zie package&#xA;Default: Zie package&#xA;Description: Deze constructie is al dan niet afgeleid van een &quot;supplier model&quot;. Wanneer je niks opgeeft wordt afleiding vastgesteld op basis van het package waarin het voorkomt.&#xA;" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Positie" xmi.id="EAID_B8C3C35D_616A_9b61_8EF0_0DF0ED2F67A4" value="#NOTES#Description: De positie van de construct binnen producten waarin deze opeenvolging een rol speelt.&#xA;" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Ref-release" xmi.id="EAID_277EE4EB_C178_e0c1_95D2_51BAF50311EC" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Ref-version" xmi.id="EAID_5BDC39D0_165D_3e16_964A_5A269F631BC1" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Release" xmi.id="EAID_3AE37A01_180E_bb18_9A25_0EDECB5AC5C6" value="20230920" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
		<UML:TaggedValue tag="Supplier-package-name" xmi.id="EAID_96853A7B_EB48_f9eb_8012_B99214CF518A" value="#NOTES#Description: De naam van de supplier (domein of view) package. Deze naam wordt opgegeven als deze niet gelijk is aan de naam van het package waar de tagged value op geplaatst is.&#xA;" modelElement="EAID_A902CAE6_49D8_460d_9335_2B9DF0489734"/>
