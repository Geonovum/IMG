														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={6FEE7BF0-F002-4a30-B5AC-2B9C7D3465AA}$XID;$NAM=Stereotypes$NAM;$TYP=connector property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Generalisatie;FQName=MIM::Generalisatie;@ENDSTEREO;$DES;$CLT={4C2C87CF-D772-4c84-A82B-A8E0A11E1697}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
