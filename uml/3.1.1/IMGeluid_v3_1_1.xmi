		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_C751_5dc7_AF55_CCDDBC055E6A" value="nen 3610#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xA;" modelElement="EAID_65280E13_7AA2_451f_9E14_CD7798636FAC"/>
		<UML:TaggedValue tag="Herkomst definitie" xmi.id="EAID_1FAA1D3E_1B62_631b_8488_58F152D30F36" value="nen 3610#NOTES#Description: De registratie of het informatiemodel waaruit de definitie is overgenomen dan wel een aanduiding die aangeeft uit welke bronnen de definitie is samengesteld.&#xA;" modelElement="EAID_65280E13_7AA2_451f_9E14_CD7798636FAC"/>
		<UML:TaggedValue tag="Kwaliteit" xmi.id="EAID_B108BD8E_2332_7b23_B3FE_85D7E98B9303" value="#NOTES#Description: Beschrijving van de mate waarin in de registratie opgenomen objecten van het desbetreffende type volledig, juist, actueel, nauwkeurig en betrouwbaar zijn.&#xA;" modelElement="EAID_65280E13_7AA2_451f_9E14_CD7798636FAC"/>
		<UML:TaggedValue tag="Populatie" xmi.id="EAID_2D3C6693_CC37_aecc_AA19_2C63CD5264C1" value="&lt;memo&gt;" modelElement="EAID_65280E13_7AA2_451f_9E14_CD7798636FAC"/>
		<UML:TaggedValue tag="Toelichting" xmi.id="EAID_50A2721A_D0BE_44d0_B1E3_68A6F28BC73D" value="&lt;memo&gt;#NOTES#Een reëel of fysiek object is een tastbaar begrensd object dat gekenmerkt wordt door zijn materiele samenstelling en structuur." modelElement="EAID_65280E13_7AA2_451f_9E14_CD7798636FAC"/>
		<UML:TaggedValue tag="Begrip" xmi.id="EAID_EBF7A679_4E9D_974e_81E1_95E6989ECD7F" value="http://definities.geostandaarden.nl/nen3610-2022/id/begrip/bodem#NOTES#Description: Verwijzing naar een begrip, vanuit een modelelement, waarmee wordt aangegeven op welk begrip, of begrippen, het informatiemodel element is gebaseerd. De verwijzing heeft de vorm van een term of een URI.&#xA;" modelElement="EAID_85C106F3_B76B_4f9e_ACCF_AABCA792A479"/>
