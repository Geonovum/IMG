		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_C751_5dc7_82CC_4B8AB2A548F0" value="nen 3610#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xA;" modelElement="EAID_9426A967_757C_4889_ACD5_B1E420BF7E90"/>
