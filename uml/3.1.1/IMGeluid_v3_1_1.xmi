														</UML:Attribute>
														<UML:Attribute name="maaiveld" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_CCDDE1A3_5915_41e8_986C_F9F9271380A7"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;3D-geometrie die evenveel punten bevat als het attribuut 'geometrie' met dezelde x- en y- co&amp;#246;rdinaten. De z-co&amp;#246;rdinaat bevat de maaiveldhoogte. Deze geometrie bevat dus een projectie van het Vegetatiegebied  op het maaiveld.  &#xA;-- Toelichting --&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Uit het verschil van de z-co&amp;#246;rdinaten tussen de geometrie van een Vegetatiegebied en onderkantVegetatiegebied is de hoogte van een Vegetatiegebied t.o.v. het maaiveld te bepalen,&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;-- Regels--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Als maaiveld gevuld is moet deze evenveel punten bevatten als de geometrie van een Vegetatiegebied met dezelfde x- en y-co&amp;#246;rdinaten in dezelfde volgorde.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="GM_Surface"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
