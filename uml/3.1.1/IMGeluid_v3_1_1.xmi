													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Het bodemvlak (vloer) van de niet overkapte helling die een tunnel verbindt met het maaiveld.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Dit betreft het bodemvlak van de tunnelbak.&lt;/li&gt;&#xA;	&lt;li&gt;De wanden van de tunnelbak behoren niet tot de geometrie van dit object en worden als Geluidschermdeel met schermtype=tunnelbakwand gemodelleerd.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;"/>
