																<UML:TaggedValue tag="Alternatieve naam" xmi.id="EAID_4BF34B01_03CD_6303_B688_EF5FAFDB083E">
																	<XMI.extension xmi.extender="Enterprise Architect 2.5">
																		<UML:Comment name="Description: De naam in natuurlijke of formele taal; afhankelijk van gekozen aanpak. Een alternatieve naam.&#xA;"/>
																	</XMI.extension>
																</UML:TaggedValue>
																<UML:TaggedValue tag="Definitie" xmi.id="EAID_5F3916B1_C37D_92c3_A939_7B7DB0147750">
																	<XMI.extension xmi.extender="Enterprise Architect 2.5">
