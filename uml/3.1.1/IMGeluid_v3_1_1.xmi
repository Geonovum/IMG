		<UML:Diagram name="ModelReëelObject-detail" xmi.id="EAID_08E1BC7F_D65C_4f42_8D97_FE13525E9C65" diagramType="ClassDiagram" owner="EAPK_AAB6354B_685C_4f41_8AD2_92A70007CA4D" toolName="Enterprise Architect 2.5">
			<UML:ModelElement.taggedValue>
				<UML:TaggedValue tag="documentation" value="Semantisch deelmodel van NEN 3610 over Reeel object. Zie paragraaf 8.4.4.2.2 NEN 3610:2022.&#xA;&#xA;Een reeel object is een geo-object dat zich geheel materieel manifesteerd. Het is daarmee een tastbaar begrensd object dat gekenmerkt wordt door zijn materiele samenstelling en structuur."/>
