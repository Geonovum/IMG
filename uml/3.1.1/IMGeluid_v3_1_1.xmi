																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={E6AA8667-23C4-44a9-99F3-4D9AF88C1BE3}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Attribuutsoort;FQName=MIM::Attribuutsoort;@ENDSTEREO;$DES;$CLT={E312F96C-226A-40db-B9D0-16A23FBEFAF0}$CLT;$ENDXREF;"/>
