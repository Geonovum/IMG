													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Toelichting--&#xA;&#xA;Alleen voor Industrieterreinen moet ook de Lnight waarden worden opgenomen  naast de normale attributen van het Object &quot;Geluidproductieplafond&quot;.&#xA;&#xA;--Regels--&#xA;Relatie bestaat alleen binnen domein industrie.&#xA;"/>
