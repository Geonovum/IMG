														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={BE432B57-A6D6-4cde-8031-1F8155092586}$XID;$NAM=Stereotypes$NAM;$TYP=connector property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Generalisatie;FQName=MIM::Generalisatie;@ENDSTEREO;$DES;$CLT={FA63B332-6B2F-46e4-B020-3A22BDE206D5}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
