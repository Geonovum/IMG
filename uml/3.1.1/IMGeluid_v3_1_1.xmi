															</UML:ModelElement.taggedValue>
														</UML:Attribute>
														<UML:Attribute name="absorptiefractie" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_685DCF87_F26E_4f76_960B_F61B2E2FA0BA"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Aanduiding voor de akoestische hardheid van de bodem.&#xA;&#xA;--Toelichting--&#xA;Aanduiding voor de akoestische hardheid van de bodem.absorptiefractie: hard (0), zacht (1) en half (0,5).&#xA;&#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Dit is gewijzigd van een discrete naar een continue waarde. De gemiddelde absorptiefractie in een gebied wordt berekend door middeling van de absorptiefracties van de deelgebieden, waarbij een weging wordt toegepast die is gebaseerd op het quoti&amp;#235;nt van de lengte van het deelgebied en de lengte van het totale gebied.&lt;/li&gt;&#xA;	&lt;li&gt;Als de lengte van het middengebied nihil is, wordt de gemiddelde absorptiefractie van het middengebied op 1 gesteld. Voor akoestisch hard gebied (water, geasfalteerde vlakken en dergelijke) is de absorptiefractie gelijk aan nul. Voor akoestisch zacht gebied, zoals grasland, akkerland en bos- en duingrond is de absorptiefractie gelijk aan 1,0. Bij een wegdektype dat significant absorberende eigenschappen heeft (zoals ZOAB en (Fijn) tweelaags ZOAB), wordt een absorptiefractie van 0,5 aangehouden.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="Decimal"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
																<UML:TaggedValue tag="precision" value="0"/>
																<UML:TaggedValue tag="scale" value="0"/>
																<UML:TaggedValue tag="static" value="0"/>
																<UML:TaggedValue tag="stereotype" value="Attribuutsoort"/>
																<UML:TaggedValue tag="collection" value="false"/>
																<UML:TaggedValue tag="position" value="1"/>
																<UML:TaggedValue tag="lowerBound" value="1"/>
																<UML:TaggedValue tag="upperBound" value="1"/>
																<UML:TaggedValue tag="duplicates" value="0"/>
