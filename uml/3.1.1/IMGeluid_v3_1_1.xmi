												<UML:Class name="Geluidcontour" xmi.id="EAID_CE246B5D_6AD8_4ab4_9248_3E1A22EB06B2" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Een lijn die punten met een gelijke geluidbelasting verbindt.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Per 1 dB moet een contour worden berekend.&lt;/li&gt;&#xA;	&lt;li&gt;Bij luchtvaart is het bereik van 48 dB Lden tot 70 dB.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
