		<UML:TaggedValue tag="Herkomst" xmi.id="EAID_6B33862D_C751_5dc7_9671_C1FE422A41D8" value="nen 3610#NOTES#Description: De registratie of het informatiemodel waaraan het modelelement ontleend is dan wel de eigen organisatie indien het door de eigen organisatie toegevoegd is.&#xA;" modelElement="EAID_8A4801C0_D263_4a0b_99C5_A0C7A67FFE62"/>
