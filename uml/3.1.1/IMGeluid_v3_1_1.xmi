												<UML:Class name="Documentverwijzing" xmi.id="EAID_7E137496_1028_4af5_9367_569358A2167B" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Verwijzing naar het onderliggende besluit voor GPP, onderliggende bepaling voor BGE of onderliggende monitoringsrapportage voor een Monitoringswaarde of overige besluiten of meldingen.&#xA;&#xA;--Toelichting--&#xA;De bronhouder is verantwoordelijk voor het onderhouden van een stabiele verwijzing. &#xA;Het is toegestaan om meerdere besluiten bij een GPP op te nemen, inclusief een tijdelijk ontheffingsbesluit.&#xA;Een documentverwijzing kan verbonden zijn aan een monitoringresultaat dat toebehooort aan een basisgeluidemissieobject. Om die reden heeft een documentverwijzing &lt;i&gt;geen&lt;/i&gt; of &lt;i&gt;meerdere&lt;/i&gt; geluidproductieplafondobjecten [0..*].&#xA;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
