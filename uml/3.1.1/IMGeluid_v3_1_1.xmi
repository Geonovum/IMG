												<UML:Class name="Brug" xmi.id="EAID_F36131A1_FE84_4230_B41A_3E55575D3C80" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Een brug is een vaste of beweegbare verbinding voor het verkeer over een obstakel.&#xA;&#xA;--Toelichting--&#xA;Dit object is voor de berekening van het GPP op twee manieren relevant:&#xA;&lt;ol&gt;&#xA;	&lt;li&gt;Het bepaalt waar de brugtoeslag geldt&lt;/li&gt;&#xA;	&lt;li&gt;Als het een betonnen brug is, geldt de brug als een reflecterend bodemvlak op hoogte, met z-waarde t.o.v. N.A.P. afgeleid van spoorhoogte (spoorhoogte minus 20cm).&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&#xA;--Regels--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Een brug moet een 3D-geometrie hebben.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
														<UML:TaggedValue tag="package" value="EAPK_326D164B_0527_4316_9430_62BB926CBC78"/>
														<UML:TaggedValue tag="date_created" value="2020-01-22 17:17:32"/>
														<UML:TaggedValue tag="date_modified" value="2024-07-10 11:00:42"/>
														<UML:TaggedValue tag="gentype" value="Java"/>
														<UML:TaggedValue tag="tagged" value="0"/>
														<UML:TaggedValue tag="package_name" value="AlgObject"/>
														<UML:TaggedValue tag="phase" value="1.0"/>
														<UML:TaggedValue tag="author" value="g.trouborst"/>
														<UML:TaggedValue tag="complexity" value="1"/>
														<UML:TaggedValue tag="product_name" value="Java"/>
														<UML:TaggedValue tag="status" value="Proposed"/>
														<UML:TaggedValue tag="stereotype" value="Objecttype"/>
														<UML:TaggedValue tag="tpos" value="32"/>
														<UML:TaggedValue tag="ea_localid" value="12569"/>
														<UML:TaggedValue tag="ea_eleType" value="element"/>
														<UML:TaggedValue tag="style" value="BackColor=-1;BorderColor=-1;BorderWidth=1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={66B66054-D891-4a45-83E9-E7AF6EE08525}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Objecttype;FQName=MIM::Objecttype;@ENDSTEREO;$DES;$CLT={F36131A1-FE84-4230-B41A-3E55575D3C80}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
													</UML:ModelElement.taggedValue>
													<UML:Classifier.feature>
														<UML:Attribute name="geluidtoeslag" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_FB0866C8_1438_445a_BB63_B798A00E1626"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Gegevensgroep"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Het verschil tussen de emissie van de door het kunstwerk be&amp;#239;nvloede bronnen en dezelfde bronnen zonder de invloed van het kunstwerk. Per spoorvoertuigcategorie kan een toeslag per octaafband worden opgenomen.&#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Het rijden over een stalen kunstwerk zal in het algemeen leiden tot een toename van de geluidemissie.&lt;/li&gt;&#xA;	&lt;li&gt;Deze toename wordt veroorzaakt door enerzijds een toename van het rolgeluid van het spoorvoertuig en anderzijds de geluidafstraling van het stalen kunstwerk zelf.&lt;/li&gt;&#xA;	&lt;li&gt;Bij stalen kunstwerken wordt in de rekenmethode deze toename van de geluidemissie gekarakteriseerd door een geluidemissietoeslag.&lt;/li&gt;&#xA;	&lt;li&gt;Deze geluidemissietoeslag wordt bepaald per voertuigcategorie, per octaafband.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="Geluidtoeslag"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
																<UML:TaggedValue tag="precision" value="0"/>
																<UML:TaggedValue tag="scale" value="0"/>
																<UML:TaggedValue tag="static" value="0"/>
																<UML:TaggedValue tag="stereotype" value="Gegevensgroep"/>
																<UML:TaggedValue tag="collection" value="false"/>
																<UML:TaggedValue tag="position" value="0"/>
