																	<XMI.extension xmi.extender="Enterprise Architect 2.5">
																		<UML:Comment name="Description: De registratie of het informatiemodel waaruit de definitie is overgenomen dan wel een aanduiding die aangeeft uit welke bronnen de definitie is samengesteld.&#xA;"/>
																	</XMI.extension>
																</UML:TaggedValue>
