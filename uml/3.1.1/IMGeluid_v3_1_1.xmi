										<UML:Class name="GM_MultiSurface" xmi.id="EAID_28E881FF_2361_44aa_8FF9_08604E438AFE" visibility="public" namespace="EAPK_B33BDD4E_8D50_46c3_9316_648EFBAD47A9" isRoot="false" isLeaf="false" isAbstract="false">
											<UML:ModelElement.stereotype>
												<UML:Stereotype name="Primitief datatype"/>
											</UML:ModelElement.stereotype>
											<UML:ModelElement.taggedValue>
												<UML:TaggedValue tag="documentation" value="-- Definitie --&#xA;Multivlak. Verzameling van vlakken die gezamenlijk &amp;#233;&amp;#233;n object vormen (instanties van GM_Surface).&#xA;-- Toelichting--&#xA;Vlakken in een multisurface mogen elkaar niet overlappen. In een simple multisurface mogen vlakken elkaar alleen raken in een eindig aantal punten (wel punten maar geen grenzen gemeenschappelijk)&#xA;Zie verder: https://docs.geostandaarden.nl/nen3610/gimeg/#gm_multisurface."/>
												<UML:TaggedValue tag="isSpecification" value="false"/>
												<UML:TaggedValue tag="ea_stype" value="PrimitiveType"/>
