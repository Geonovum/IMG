												<UML:Class name="Procesinstallatiegebied" xmi.id="EAID_F66BFCFE_8850_4cf0_8769_084A9455A966" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Gebied dat een dempende invloed heeft op de geluidemissie van bronnen. &#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Een procesinstallatiegebied wordt gebruikt om te simuleren hoe de fysieke installaties van geluidbronnen een dempende werking hebben op andere geluidbronnen.&lt;/li&gt;&#xA;	&lt;li&gt;Het is bijvoorbeeld mogelijk dat een installatie met een geluidemissie een andere installatie dempt.&lt;/li&gt;&#xA;	&lt;li&gt;Een procesinstallatiegebied wordt gebruikt om het dempende effect hiervan te simuleren.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
