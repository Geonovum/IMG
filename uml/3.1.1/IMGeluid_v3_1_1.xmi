															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Gegevensgroep"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Verzameling van gegevens over het gemiddeld aantal voertuigverplaatsingen per dagdeel, spoorvoertuigcategorie, profieltype, rijrichting, treintype, op het betreffende Spoordeel.&#xA;&#xA;--Toelichting--&#xA;Dit is een repeterende gegevensgroep; een Spoordeel kan meerdere gegevensgroepen met intensiteitsgegevens bevatten.&#xA;&#xA;---Notes voor beheer--&#xA;Aangezien bij spoor er veel verschillende soorten spoorvoertuigcategorieen zijn is het niet mogelijk een vaste multipliciteit hiervoor te bepalen. Niet over ieder spoordeel rijd elke spoorvoertuigcategorie.&#xA;&#xA;"/>
																<UML:TaggedValue tag="type" value="IntensiteitgegevensSpoor"/>
