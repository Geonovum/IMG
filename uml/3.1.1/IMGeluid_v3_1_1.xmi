												</UML:Class>
												<UML:Class name="Geluidberekeningobject" xmi.id="EAID_97ED59FE_9FCA_49a6_8F07_214E48000B76" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Object met achtergrondinformatie over een geluidberekening die van toepassing is voor een Geluidgegevenscollectie. &#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Dit object is toegevoegd om het transparant te maken welke partij het akoestisch onderzoek heeft uitgevoerd met welke software.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Bij spoor kunnen twee verschillende geluidberekeningobjecten voorkomen, omdat spoorweg emplacementen onder de industrie rekenvoorschriften vallen.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Is geen gegevensgroep omdat uit 1 geluidberekening verschillende geluidproductieplafonds kunnen worden berekend.We willen niet per GPP een geluidberekening opnieuw opslaan.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Dit moet een object zijn omdat uit dezelfde berekening meerdere Geluidproductieplafondobjecten kunnen zijn voortgekomen.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
