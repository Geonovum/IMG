																<UML:TaggedValue tag="ea_localid" value="41560"/>
																<UML:TaggedValue tag="styleex" value="volatile=0;union=0;"/>
																<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={2C9BAF93-D122-4ed3-A435-B841EC53B68B}$XID;$NAM=Stereotypes$NAM;$TYP=attribute property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Attribuutsoort;FQName=MIM::Attribuutsoort;@ENDSTEREO;$DES;$CLT={186526E2-753D-471c-95A3-FAE7CD504F36}$CLT;$ENDXREF;"/>
