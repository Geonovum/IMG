										<UML:Class name="Decimal" xmi.id="EAID_685DCF87_F26E_4f76_960B_F61B2E2FA0BA" visibility="public" namespace="EAPK_0695E496_3542_429b_84DD_E288687162C8" isRoot="false" isLeaf="false" isAbstract="false">
