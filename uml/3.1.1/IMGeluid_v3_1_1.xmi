														<UML:Attribute name="uitstralingsrichting" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_C522F5BC_D298_4887_8030_D6271385F840"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Richting waarop GeluidbronIndustrie emissie uitstraalt.&#xA;&#xA;--Toelichting--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;De uitstralingsrichting wordt bepaald door een 'openingshoek' en een 'uitstralingsrichting'.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;De uitstralingsrichting is: Richting waar emissie naar uitstraalt.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;De openingshoek is: Opening van de hoek van emissie-uitstraling met als midden de uitstralingsrichting.&lt;/li&gt;&#xA;	&lt;li&gt;Deze hoeken worden uitgedrukt in graden volgens de kompasrichtingen.&lt;/li&gt;&#xA;	&lt;li&gt;Wanneer geen uitstralingsrichting bekend is, wordt default 360 graden ingevuld bij de openingshoek van de UitstralingsrichtingWaarde en 0 graden bij de uitstralingsrichting.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;"/>
																<UML:TaggedValue tag="type" value="Uitstralingsrichtingwaarde"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
																<UML:TaggedValue tag="precision" value="0"/>
