												<UML:TaggedValue tag="tagged" value="0"/>
												<UML:TaggedValue tag="package2" value="EAID_94A5BF41_39F9_48c6_85C6_FFDAB5DC4B68"/>
												<UML:TaggedValue tag="package_name" value="NEN3610"/>
