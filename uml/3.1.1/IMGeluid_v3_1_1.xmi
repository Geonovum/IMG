												<UML:Class name="Kunstwerk" xmi.id="EAID_E7C0AB60_EC07_4e4f_8F38_E279188D028A" visibility="public" namespace="EAPK_326D164B_0527_4316_9430_62BB926CBC78" isRoot="false" isLeaf="false" isAbstract="false" isActive="false">
													<UML:ModelElement.stereotype>
														<UML:Stereotype name="Objecttype"/>
													</UML:ModelElement.stereotype>
													<UML:ModelElement.taggedValue>
														<UML:TaggedValue tag="documentation" value="--Definitie--&#xA;Een civiel-technisch werk voor de infrastructuur van wegen, water, spoorbanen, waterkeringen en/of leidingen.&#xA;&#xA;---Notes voor beheer--&#xA;Let op: definitie overgeonomen van KunstwerkDEEL uit BGT. In BGT vallen de objecten die in IM GEluid als subtypen van een kunstwerk zijn gemodelleerd niet (allemaal) onder een kunstwerkdeel, zoals in de BGT omschreven&#xA;&#xA;https://definities.geostandaarden.nl/concepten/imgeo/id/begrip/Kunstwerkdeel"/>
														<UML:TaggedValue tag="isSpecification" value="false"/>
														<UML:TaggedValue tag="ea_stype" value="Class"/>
														<UML:TaggedValue tag="ea_ntype" value="0"/>
														<UML:TaggedValue tag="version" value="1.0"/>
														<UML:TaggedValue tag="package" value="EAPK_326D164B_0527_4316_9430_62BB926CBC78"/>
														<UML:TaggedValue tag="date_created" value="2020-01-23 10:41:28"/>
														<UML:TaggedValue tag="date_modified" value="2024-08-14 14:24:34"/>
														<UML:TaggedValue tag="gentype" value="Java"/>
														<UML:TaggedValue tag="tagged" value="0"/>
														<UML:TaggedValue tag="package_name" value="AlgObject"/>
														<UML:TaggedValue tag="phase" value="1.0"/>
														<UML:TaggedValue tag="author" value="g.trouborst"/>
														<UML:TaggedValue tag="complexity" value="1"/>
														<UML:TaggedValue tag="product_name" value="Java"/>
														<UML:TaggedValue tag="status" value="Proposed"/>
														<UML:TaggedValue tag="stereotype" value="Objecttype"/>
														<UML:TaggedValue tag="tpos" value="31"/>
														<UML:TaggedValue tag="ea_localid" value="12567"/>
														<UML:TaggedValue tag="ea_eleType" value="element"/>
														<UML:TaggedValue tag="style" value="BackColor=-1;BorderColor=-1;BorderWidth=1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
														<UML:TaggedValue tag="$ea_xref_property" value="$XREFPROP=$XID={D234A3A7-4591-41b4-B537-74AEEFB0F60F}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=Objecttype;FQName=MIM::Objecttype;@ENDSTEREO;$DES;$CLT={E7C0AB60-EC07-4e4f-8F38-E279188D028A}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
													</UML:ModelElement.taggedValue>
													<UML:Classifier.feature>
														<UML:Attribute name="geometrie" changeable="none" visibility="public" ownerScope="instance" targetScope="instance">
															<UML:Attribute.initialValue>
																<UML:Expression/>
															</UML:Attribute.initialValue>
															<UML:StructuralFeature.type>
																<UML:Classifier xmi.idref="EAID_CCDDE1A3_5915_41e8_986C_F9F9271380A7"/>
															</UML:StructuralFeature.type>
															<UML:ModelElement.stereotype>
																<UML:Stereotype name="Attribuutsoort"/>
															</UML:ModelElement.stereotype>
															<UML:ModelElement.taggedValue>
																<UML:TaggedValue tag="description" value="--Definitie--&#xA;Als 3D of 2D vlak gemodelleerde meetkundige representatie van een kunstwerk.&#xA;&#xA;--Toelichting-- &#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Hierbij gaat het specifiek om een brug, een overkapping, een tunnelbak of een tunnel.&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&#xA;&#xA;---Notes voor beheer--&#xA;&lt;ul&gt;&#xA;	&lt;li&gt;Alleen een brug wordt gebruikt in de GPP-berekening. De overige objecten hebben alleen een informatieve waarde.&lt;/li&gt;&#xA;&lt;/ul&gt;"/>
																<UML:TaggedValue tag="type" value="GM_Surface"/>
																<UML:TaggedValue tag="derived" value="0"/>
																<UML:TaggedValue tag="containment" value="Not Specified"/>
																<UML:TaggedValue tag="length" value="0"/>
																<UML:TaggedValue tag="ordered" value="0"/>
